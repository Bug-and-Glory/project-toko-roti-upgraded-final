<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Dashboard Admin - YumYum Bakery</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<link rel="stylesheet" href="/css/admin.css">
</head>

<body>

<div class="dashboard-container">

<aside class="sidebar" id="sidebar">

    <div class="logo-area">
    <img src="/logo/logo_nama.png" alt="YumYum Bakery">
    </div>

    <ul class="sidebar-menu">

        <li>
            <a href="/admin/dashboard" class="active">
                <i class="fa-solid fa-house"></i>
                Dashboard
            </a>
        </li>

        <li>
            <a href="/admin/lihat-menu">
                <i class="fa-solid fa-shop"></i>
                Lihat Menu
            </a>
        </li>

        <li>
            <a href="/admin/kelola-menu">
                <i class="fa-solid fa-pen-to-square"></i>
                Kelola Menu
            </a>
        </li>

        <li>
            <a href="/admin/history-admin">
                <i class="fa-solid fa-clock-rotate-left"></i>
                History
            </a>
        </li>

        <li>
            <a href="/admin/login">
                <i class="fa-solid fa-right-from-bracket"></i>
                Logout
            </a>
        </li>

    </ul>

</aside>

<div class="main-content">

    <nav class="top-navbar">

        <button class="sidebar-toggle d-lg-none">
            <i class="fa-solid fa-bars"></i>
        </button>

        <h4 class="page-title">
            Dashboard
        </h4>

        <div class="admin-profile dropdown">

            <a href="#" data-bs-toggle="dropdown">

                <img src="/logo/logo_aja.png" alt="Admin">

                <span>
                    <%= admin ? admin.name : 'Admin Bakery' %>
                </span>

            </a>

            <ul class="dropdown-menu dropdown-menu-end">

                <li>
                    <a class="dropdown-item" href="#">
                        Profile
                    </a>
                </li>

                <li>
                    <a class="dropdown-item text-danger" href="/logout">
                        Logout
                    </a>
                </li>

            </ul>

        </div>

    </nav>

    <div class="content-wrapper">

        <div class="row g-4">

            <div class="col-xl-3 col-md-6">

                <div class="stats-card">

                    <div class="stats-icon">
                        <i class="fa-solid fa-box"></i>
                    </div>

                    <h2>
                        <%= totalMenu || 120 %>
                    </h2>

                    <p>Total Menu</p>

                </div>

            </div>

            <div class="col-xl-3 col-md-6">

                <div class="stats-card">

                    <div class="stats-icon">
                        <i class="fa-solid fa-cart-shopping"></i>
                    </div>

                    <h2>
                        <%= totalOrder || 245 %>
                    </h2>

                    <p>Total Order</p>

                </div>

            </div>

            <div class="col-xl-3 col-md-6">

                <div class="stats-card">

                    <div class="stats-icon">
                        <i class="fa-solid fa-money-bill-wave"></i>
                    </div>

                    <h2>
                        Rp <%= totalRevenue || '24.500.000' %>
                    </h2>

                    <p>Total Pendapatan</p>

                </div>

            </div>

            <div class="col-xl-3 col-md-6">

                <div class="stats-card">

                    <div class="stats-icon">
                        <i class="fa-solid fa-clock-rotate-left"></i>
                    </div>

                    <h2>
                        <%= totalHistory || 580 %>
                    </h2>

                    <p>Total Riwayat</p>

                </div>

            </div>

        </div>

        <div class="row mt-4">

            <div class="col-lg-8">
                <div class="custom-card">
                    <div class="section-header">
                        <h5>Riwayat Transaksi Terbaru</h5>
                    </div>
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Tanggal</th>
                                <th>Pelanggan</th>
                                <th>Total Pembayaran</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Data ini nantinya dirender dari backend Node.js -->
                            <tr>
                                <td>02 Juli 2026</td>
                                <td>Budi Santoso</td>
                                <td>Rp 150.000</td>
                            </tr>
                            <tr>
                                <td>02 Juli 2026</td>
                                <td>Siti Aminah</td>
                                <td>Rp 75.000</td>
                            </tr>
                            <tr>
                                <td>01 Juli 2026</td>
                                <td>Ahmad Reza</td>
                                <td>Rp 210.000</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col-lg-4">

                <div class="custom-card">

                    <h5 class="mb-4">
                        Quick Actions
                    </h5>

                    <a href="/admin/kelola-menu" class="quick-btn">
                        <i class="fa-solid fa-plus"></i>
                        Tambah Menu
                    </a>

                    <a href="/admin/lihat-menu" class="quick-btn">
                        <i class="fa-solid fa-shop"></i>
                        Lihat Semua Menu
                    </a>

                    <a href="/admin/history-admin" class="quick-btn">
                        <i class="fa-solid fa-clock-rotate-left"></i>
                        Lihat History
                    </a>

                </div>

            </div>

        </div>

    </div>

    <footer class="footer">
        © 2026 YumYum Bakery Admin Dashboard
    </footer>

</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script src="/js/admin.js"></script>

</body>
</html>