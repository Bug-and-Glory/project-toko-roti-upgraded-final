<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>History Transaksi - YumYum Bakery</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/admin.css">
</head>

<body>

<div class="dashboard-container">

<aside class="sidebar">
    <div class="logo-area">
        <img src="/logo/logo_nama.png" alt="YumYum Bakery">
    </div>

    <ul class="sidebar-menu">
        <li>
            <a href="/admin/dashboard">
                <i class="fa-solid fa-house"></i>
                Dashboard
            </a>
        </li>
        <li>
            <a href="/admin/lihat-menu">
                <i class="fa-solid fa-shop"></i>
                Lihat Menu
            </a>
        </li>
        <li>
            <a href="/admin/kelola-menu">
                <i class="fa-solid fa-pen-to-square"></i>
                Kelola Menu
            </a>
        </li>
        <li>
            <a href="/admin/history-admin" class="active">
                <i class="fa-solid fa-clock-rotate-left"></i>
                History
            </a>
        </li>
        <li>
            <a href="/admin/login">
                <i class="fa-solid fa-right-from-bracket"></i>
                Logout
            </a>
        </li>
    </ul>
</aside>

<div class="main-content">
    <nav class="top-navbar">
        <h4 class="page-title">
            Riwayat Transaksi Pelanggan
        </h4>
    </nav>

    <div class="content-wrapper">
        <div class="custom-card">
            
            <!-- Filter Section -->
            <div class="row g-3 mb-4">
                <div class="col-lg-6">
                    <input type="text" class="form-control" placeholder="Cari nama pelanggan...">
                </div>
                <div class="col-lg-4">
                    <input type="date" class="form-control">
                </div>
                <div class="col-lg-2">
                    <button class="btn w-100" style="background-color: #0448A8; color: white;">
                        Filter
                    </button>
                </div>
            </div>

            <!-- Table Section -->
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Tanggal</th>
                            <th>Order ID</th>
                            <th>Pelanggan</th>
                            <th>Total Pembayaran</th>
                            <th>Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>02 Juli 2026</td>
                            <td>#ORD-0992</td>
                            <td>Budi Santoso</td>
                            <td>Rp 150.000</td>
                            <td><button class="btn btn-sm btn-outline-secondary">Detail</button></td>
                        </tr>
                        <tr>
                            <td>02 Juli 2026</td>
                            <td>#ORD-0991</td>
                            <td>Siti Aminah</td>
                            <td>Rp 75.000</td>
                            <td><button class="btn btn-sm btn-outline-secondary">Detail</button></td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <nav class="mt-4">
                <ul class="pagination justify-content-end">
                    <li class="page-item">
                        <a class="page-link" href="#">Previous</a>
                    </li>
                    <li class="page-item active">
                        <a class="page-link" href="#">1</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="#">2</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="#">Next</a>
                    </li>
                </ul>
            </nav>

        </div>
    </div>

    <footer class="footer">
        © 2026 YumYum Bakery Admin Dashboard
    </footer>
</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/admin.js"></script>

</body>
</html>