<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Kelola Menu - YumYum Bakery</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<link rel="stylesheet" href="/css/admin.css">
</head>

<body>

<div class="dashboard-container">

<aside class="sidebar">

    <div class="logo-area">
    <img src="/logo/logo_nama.png" alt="YumYum Bakery">
    </div>  

    <ul class="sidebar-menu">

        <li>
            <a href="/admin/dashboard">
                <i class="fa-solid fa-house"></i>
                Dashboard
            </a>
        </li>

        <li>
            <a href="/admin/lihat-menu">
                <i class="fa-solid fa-shop"></i>
                Lihat Menu
            </a>
        </li>

        <li>
            <a href="/admin/kelola-menu" class="active">
                <i class="fa-solid fa-pen-to-square"></i>
                Kelola Menu
            </a>
        </li>

        <li>
            <a href="/admin/history-admin">
                <i class="fa-solid fa-clock-rotate-left"></i>
                History
            </a>
        </li>

        <li>
            <a href="/admin/login">
                <i class="fa-solid fa-right-from-bracket"></i>
                Logout
            </a>
        </li>

    </ul>

</aside>

<div class="main-content">

    <nav class="top-navbar">

        <h4 class="page-title">
            Kelola Menu
        </h4>

        <button
            class="btn btn-gold"
            data-bs-toggle="modal"
            data-bs-target="#addMenuModal">

            <i class="fa-solid fa-plus"></i>
            Tambah Menu

        </button>

    </nav>

    <div class="content-wrapper">

        <div class="custom-card">

            <div class="table-responsive">

                <table class="table align-middle">

                    <thead>

                    <tr>

                        <th>Foto</th>
                        <th>Nama Menu</th>
                        <th>Kategori</th>
                        <th>Harga</th>
                        <th>Status</th>
                        <th>Aksi</th>

                    </tr>

                    </thead>

                    <tbody>

                    <% if(menuList && menuList.length){ %>

                        <% menuList.forEach(menu => { %>

                        <tr>

                            <td>
                                <img
                                src="<%= menu.image %>"
                                class="menu-image">
                            </td>

                            <td>
                                <%= menu.name %>
                            </td>

                            <td>
                                <%= menu.category %>
                            </td>

                            <td>
                                Rp <%= menu.price %>
                            </td>

                            <td>

                                <% if(menu.status === 'Tersedia'){ %>

                                <span class="badge bg-success">
                                    Tersedia
                                </span>

                                <% } else { %>

                                <span class="badge bg-danger">
                                    Habis
                                </span>

                                <% } %>

                            </td>

                            <td>

                                <button
                                    class="btn btn-sm btn-secondary"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editMenuModal">

                                    <i class="fa-solid fa-pen"></i>

                                </button>

                                <button
                                    class="btn btn-sm btn-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteMenuModal">

                                    <i class="fa-solid fa-trash"></i>

                                </button>

                            </td>

                        </tr>

                        <% }) %>

                    <% } %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <footer class="footer">

        © 2026 YumYum Bakery Admin Dashboard

    </footer>

</div>

</div>

<div class="modal fade" id="addMenuModal">

<div class="modal-dialog modal-lg">

<div class="modal-content">

<div class="modal-header">

<h5 class="modal-title">
Tambah Menu Baru
</h5>

<button
class="btn-close"
data-bs-dismiss="modal"></button>

</div>

<div class="modal-body">

<form action="/menu/add" method="POST" enctype="multipart/form-data">

<div class="row g-3">

<div class="col-md-6">
<label class="form-label">Nama Menu</label>
<input type="text" class="form-control" name="name" required>
</div>

<div class="col-md-6">
<label class="form-label">Harga</label>
<input type="number" class="form-control" name="price" required>
</div>

<div class="col-md-6">
<label class="form-label">Kategori</label>
<select class="form-select" name="category">

<option>Roti</option>
<option>Pastry</option>
<option>Cake</option>
<option>Coffee</option>

</select>
</div>

<div class="col-md-6">
<label class="form-label">Status</label>
<select class="form-select" name="status">

<option>Tersedia</option>
<option>Habis</option>

</select>
</div>

<div class="col-12">
<label class="form-label">Deskripsi</label>
<textarea class="form-control" rows="4" name="description"></textarea>
</div>

<div class="col-12">
<label class="form-label">Upload Gambar</label>
<input type="file" class="form-control" name="image">
</div>

</div>

<div class="mt-4">

<button type="submit" class="btn btn-gold">

Tambah Menu

</button>

</div>

</form>

</div>

</div>

</div>

</div>

<div class="modal fade" id="editMenuModal">

<div class="modal-dialog modal-lg">

<div class="modal-content">

<div class="modal-header">

<h5>Edit Menu</h5>

<button
class="btn-close"
data-bs-dismiss="modal"></button>

</div>

<div class="modal-body">

<form>

<div class="row g-3">

<div class="col-md-6">
<input class="form-control" value="Croissant Butter">
</div>

<div class="col-md-6">
<input class="form-control" value="25000">
</div>

<div class="col-12">
<textarea class="form-control" rows="4">Croissant premium dengan butter pilihan.</textarea>
</div>

</div>

<div class="mt-4">

<button class="btn btn-gold">

Simpan Perubahan

</button>

</div>

</form>

</div>

</div>

</div>

</div>

<div class="modal fade" id="deleteMenuModal">

<div class="modal-dialog">

<div class="modal-content">

<div class="modal-header">

<h5>Konfirmasi Hapus</h5>

<button
class="btn-close"
data-bs-dismiss="modal"></button>

</div>

<div class="modal-body">

<p>
Apakah Anda yakin ingin menghapus menu ini?
</p>

<strong>
Croissant Butter
</strong>

</div>

<div class="modal-footer">

<button
class="btn btn-secondary"
data-bs-dismiss="modal">

Batal

</button>

<button class="btn btn-danger">

Hapus

</button>

</div>

</div>

</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script src="/js/admin.js"></script>

</body>
</html>