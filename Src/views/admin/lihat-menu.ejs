<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Lihat Menu - YumYum Bakery</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<link rel="stylesheet" href="/css/admin.css">
</head>

<body>

<div class="dashboard-container">

<aside class="sidebar">

<div class="logo-area">
    <img src="/logo/logo_nama.png" alt="YumYum Bakery">
</div>

<ul class="sidebar-menu">

    <li>
            <a href="/admin/dashboard">
                <i class="fa-solid fa-house"></i>
                Dashboard
            </a>
        </li>

        <li>
            <a href="/admin/lihat-menu" class="active">
                <i class="fa-solid fa-shop"></i>
                Lihat Menu
            </a>
        </li>

        <li>
            <a href="/admin/kelola-menu">
                <i class="fa-solid fa-pen-to-square"></i>
                Kelola Menu
            </a>
        </li>

        <li>
            <a href="/admin/history-admin">
                <i class="fa-solid fa-clock-rotate-left"></i>
                History
            </a>
        </li>

        <li>
            <a href="/admin/login">
                <i class="fa-solid fa-right-from-bracket"></i>
                Logout
            </a>
        </li>

</ul>

</aside>

<div class="main-content">

<nav class="top-navbar">

<h4 class="page-title">
    Lihat Menu
</h4>

</nav>

<div class="content-wrapper">

<div class="custom-card">

<div class="table-header">

    <h5>Daftar Menu Bakery</h5>

    <div class="table-tools">

        <input
        type="text"
        class="form-control"
        placeholder="Cari menu...">

        <select class="form-select">

            <option>Semua Kategori</option>
            <option>Roti</option>
            <option>Pastry</option>
            <option>Cake</option>
            <option>Coffee</option>

        </select>

    </div>

</div>

<div class="table-responsive">

    <table class="table align-middle">

        <thead>

        <tr>
            <th>Foto</th>
            <th>Nama Menu</th>
            <th>Kategori</th>
            <th>Harga</th>
        </tr>

        </thead>

        <tbody>

        <% if(menuList && menuList.length){ %>

            <% menuList.forEach(menu => { %>

            <tr>

                <td>

                    <img
                    src="<%= menu.image %>"
                    class="menu-image">

                </td>

                <td>
                    <%= menu.name %>
                </td>

                <td>
                    <%= menu.category %>
                </td>

                <td>
                    Rp <%= menu.price %>
                </td>

            </tr>

            <% }) %>

        <% } else { %>

        <tr>

            <td colspan="4" class="text-center py-5">
                Belum ada menu tersedia.
            </td>

        </tr>

        <% } %>

        </tbody>

    </table>

</div>

</div>

</div>

<footer class="footer">
© 2026 YumYum Bakery Admin Dashboard
</footer>

</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script src="/js/admin.js"></script>

</body>
</html>