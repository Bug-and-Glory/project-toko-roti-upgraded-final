<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>History – YumYum Bakery</title>

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>

  <style>
    /* ===== CSS VARIABLES (same as index.html) ===== */
    :root {
      --navbar-bg:   #4E2609;
      --footer-bg:   #4E2609;
      --cart-btn:    #754C27;
      --cream:       #f5f0e8;
      --brown-dark:  #3b1f0e;
      --brown-mid:   #5c2d0e;
      --brown-light: #8b4513;
      --gold:        #c9922a;
      --gold-light:  #e8b84b;
      --white:       #fff;
      --text-dark:   #2b1a0a;
      --text-gray:   #666;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Poppins', sans-serif; background: var(--cream); color: var(--text-dark); }

    /* ===================================================
       NAVBAR  (identik dengan index.html)
    =================================================== */
    .navbar {
      background: var(--navbar-bg) !important;
      padding: 10px 48px;
      box-shadow: 0 3px 16px rgba(0,0,0,0.3);
    }
    .nav-logo-img { height: 50px; width: auto; object-fit: contain; }
    .nav-logo-fallback { display: flex; align-items: center; gap: 10px; }
    .nav-logo-fallback .logo-box {
      width: 48px; height: 48px; background: var(--cart-btn);
      border-radius: 8px; display: flex; align-items: center; justify-content: center;
    }
    .nav-logo-fallback .brand-name { font-family: 'Playfair Display', serif; font-weight: 700; }
    .nav-logo-fallback .brand-sub  { letter-spacing: 2px; text-transform: uppercase; font-size: 11px; }
    .navbar-nav .nav-link {
      font-family: 'Poppins', sans-serif; font-size: 13px; font-weight: 500;
      letter-spacing: 1px; text-transform: uppercase; color: #fff;
    }
    .navbar-nav .nav-link:hover,
    .navbar-nav .nav-link.active-link { color: var(--gold-light) !important; }

    .btn-cart {
      background: var(--cart-btn); color: #fff; border: none;
      padding: 10px 22px; border-radius: 8px; font-family: 'Poppins', sans-serif;
      font-size: 15px; cursor: pointer; display: flex; align-items: center; gap: 8px;
      box-shadow: 0 4px 18px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.18);
      transition: background 0.2s, transform 0.15s; text-decoration: none;
    }
    .btn-cart:hover { background: #8a5c30; transform: translateY(-1px); color: #fff; }
    .btn-cart img   { width: 20px; height: 20px; filter: brightness(0) invert(1); }

    .search-wrapper { position: relative; display: flex; align-items: center; }
    #searchInput {
      width: 0; opacity: 0; padding: 0; border: none; outline: none;
      background: rgba(255,255,255,0.15); color: #fff;
      font-family: 'Poppins', sans-serif; font-size: 13px; border-radius: 8px;
      transition: width 0.35s ease, opacity 0.35s ease, padding 0.35s ease;
    }
    #searchInput::placeholder { color: rgba(255,255,255,0.6); }
    #searchInput.open { width: 200px; opacity: 1; padding: 8px 14px; margin-right: 8px; }
    .btn-search {
      background: rgba(255,255,255,0.42); backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,0.35); width: 44px; height: 44px;
      border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center;
      box-shadow: 0 4px 14px rgba(0,0,0,0.25); transition: background 0.2s;
    }
    .btn-search:hover { background: rgba(255,255,255,0.6); }
    .btn-search img { width: 20px; height: 20px; }

    /* ===================================================
       PAGE HEADER
    =================================================== */
    .page-header {
      background: linear-gradient(135deg, var(--brown-dark) 0%, var(--brown-mid) 100%);
      padding: 56px 48px 48px;
      text-align: center;
    }
    .page-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: 2.4rem; font-weight: 700; color: #fff; margin-bottom: 8px;
    }
    .page-header p { font-size: 13px; color: rgba(255,255,255,0.6); letter-spacing: .5px; }

    /* ===================================================
       HISTORY SECTION
    =================================================== */
    .history-section { max-width: 900px; margin: 48px auto 72px; padding: 0 24px; }

    .filter-bar { display: flex; gap: 12px; margin-bottom: 32px; }
    .filter-bar input {
      flex: 1; padding: 12px 18px;
      border: 1.5px solid #ddd; border-radius: 10px;
      font-family: 'Poppins', sans-serif; font-size: 13px;
      background: var(--white); color: var(--text-dark);
      outline: none; transition: border-color .2s;
    }
    .filter-bar input:focus { border-color: var(--gold); }
    .filter-bar input::placeholder { color: #aaa; }

    /* state messages */
    .state-msg { text-align: center; padding: 72px 0; color: var(--text-gray); }
    .state-msg .icon { font-size: 3.2rem; margin-bottom: 14px; }
    .state-msg p { font-size: 15px; }

    /* ── ORDER CARD ── */
    .order-card {
      background: var(--white); border-radius: 16px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.08);
      margin-bottom: 24px; overflow: hidden;
      animation: fadeUp .4s ease both;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .card-head {
      background: #fdf6ec; padding: 18px 24px;
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 10px; border-bottom: 1px solid #ede0cb;
    }
    .order-title { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: var(--brown-dark); margin-bottom: 2px; }
    .order-customer { font-size: 13px; color: var(--text-gray); }

    .badge-date {
      background: var(--navbar-bg); color: rgba(255,255,255,0.9);
      font-size: 11px; font-weight: 500; padding: 5px 14px;
      border-radius: 20px; white-space: nowrap; letter-spacing: .3px;
    }

    .card-body-inner { padding: 20px 24px; }
    .items-label {
      font-size: 10px; font-weight: 600; text-transform: uppercase;
      letter-spacing: 1.2px; color: #aaa; margin-bottom: 14px;
    }

    .item-row {
      display: flex; align-items: center; gap: 14px;
      padding: 10px 0; border-bottom: 1px dashed #ede0cb;
    }
    .item-row:last-child { border-bottom: none; }
    .item-img { width: 50px; height: 50px; border-radius: 10px; object-fit: cover; background: #f5f0e8; flex-shrink: 0; }
    .item-name { flex: 1; font-size: 14px; font-weight: 500; }
    .item-qty  { font-size: 12px; color: var(--text-gray); }
    .item-subtotal { font-size: 13px; font-weight: 600; color: var(--brown-light); }

    .card-foot {
      background: #fdf6ec; padding: 16px 24px;
      display: flex; justify-content: flex-end; align-items: center; gap: 14px;
      border-top: 1px solid #ede0cb;
    }
    .total-label  { font-size: 13px; color: var(--text-gray); }
    .total-amount { font-family: 'Playfair Display', serif; font-size: 1.35rem; font-weight: 700; color: var(--gold); }

    /* ===================================================
       FOOTER  (identik dengan index.html)
    =================================================== */
    footer {
      background: var(--footer-bg); color: rgba(255,255,255,0.9);
      padding: 60px 48px 30px; font-family: 'Poppins', sans-serif;
    }
    .footer-logo-main { width: 100%; max-width: 220px; border: 1.5px solid #dcb786; padding: 8px; margin-bottom: 30px; object-fit: contain; }
    .footer-halal { width: 85px; height: 85px; object-fit: contain; }
    footer h4 { font-family: 'Poppins', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: #fff; margin-bottom: 14px; }
    footer ul { list-style: none; padding: 0; margin: 0; }
    footer ul li { margin-bottom: 8px; }
    footer ul li a { text-decoration: none; color: rgba(255,255,255,0.7); font-size: 13px; transition: color 0.2s; }
    footer ul li a:hover { color: var(--gold-light); }
    .contact-item { display: flex; align-items: center; gap: 10px; color: rgba(255,255,255,0.8); font-size: 13px; margin-bottom: 10px; }
    .contact-item img { width: 20px; height: 20px; object-fit: contain; filter: brightness(0) invert(1); opacity: 0.85; }
    .mt-sponsor { margin-top: 32px; }
    .sponsor-logo-box { background: #fff; border-radius: 8px; padding: 8px 10px; display: flex; align-items: center; justify-content: center; height: 40px; overflow: hidden; }
    .sponsor-logo-box img { max-width: 100%; max-height: 20px; object-fit: contain; }
    .mt-pengaduan { margin-top: 32px; }
    .complaint-section p { font-size: 12px; color: rgba(255,255,255,0.7); line-height: 1.8; margin-bottom: 0; }
    .footer-divider { border: none; border-top: 1px solid rgba(255,255,255,0.15); margin: 40px 0 16px; }
    .footer-bottom { text-align: center; font-size: 12px; color: rgba(255,255,255,0.4); }

    @media (max-width: 992px) {
      .navbar { padding: 10px 20px; }
      .page-header { padding: 40px 20px 36px; }
      .page-header h1 { font-size: 1.8rem; }
      footer { padding: 40px 20px 20px; }
    }
  </style>
</head>
<body>

<!-- ============================================================
     NAVBAR
============================================================ -->
<nav class="navbar navbar-expand-lg sticky-top">
  <div class="container-fluid px-0">
    <a class="navbar-brand ms-0" href="/">
      <img src="/assets/logo/logo_nama.png" alt="YumYum Bakery" class="nav-logo-img"
           onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
      <div class="nav-logo-fallback" style="display:none;">
        <div class="logo-box">
          <svg viewBox="0 0 48 48" fill="none" width="32" height="32">
            <ellipse cx="24" cy="28" rx="16" ry="10" fill="#c9922a"/>
            <ellipse cx="24" cy="26" rx="14" ry="8" fill="#e8b84b"/>
            <path d="M16 18 Q24 10 32 18" stroke="#c9922a" stroke-width="2.5" fill="none" stroke-linecap="round"/>
            <text x="15" y="33" font-size="9" font-weight="bold" fill="#3b1f0e" font-family="serif">YB</text>
          </svg>
        </div>
        <div>
          <span class="brand-name" style="color:#fff">YumYum</span>
          <span class="brand-sub d-block" style="color:rgba(255,255,255,0.7)">Bakery</span>
        </div>
      </div>
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarMain">
      <ul class="navbar-nav mx-auto">
        <li class="nav-item"><a class="nav-link" href="/menu">MENU</a></li>
        <li class="nav-item"><a class="nav-link" href="/store">STORE</a></li>
        <li class="nav-item"><a class="nav-link" href="/about_us">ABOUT US</a></li>
        <li class="nav-item"><a class="nav-link active-link" href="/history">HISTORY</a></li>
      </ul>
      <div class="d-flex align-items-center gap-3 mt-2 mt-lg-0">
        <a href="/cart" class="btn-cart">
          <img src="/assets/icon/keranjang.png" alt="Cart"
               onerror="this.style.display='none'"/> CART
        </a>
      </div>
    </div>
  </div>
</nav>

<!-- ============================================================
     PAGE HEADER
============================================================ -->
<div class="page-header">
  <h1>Order History</h1>
  <p>Semua riwayat transaksi pelanggan YumYum Bakery</p>
</div>

<!-- ============================================================
     HISTORY CONTENT
============================================================ -->
<div class="history-section">
  <div class="filter-bar">
    <input type="text" id="customerSearch" placeholder="Cari nama customer..." oninput="filterOrders()"/>
  </div>

  <div id="orderList">
    <div class="state-msg">
      <p>Memuat riwayat pesanan...</p>
    </div>
  </div>
</div>

<!-- ============================================================
     FOOTER
============================================================ -->
<footer>
  <div class="row g-4 mb-4">
    <div class="col-lg-3 col-md-4 col-sm-6">
      <div class="d-flex flex-column align-items-start">
        <img src="/assets/logo/logo_aja.png" alt="YumYum Bakery Logo" class="footer-logo-main"
             onerror="this.src='https://via.placeholder.com/200x100?text=YumYum+Logo'"/>
        <img src="/assets/icon/icon halal.png" alt="Halal" class="footer-halal"
             onerror="this.src='https://via.placeholder.com/80?text=Halal'"/>
      </div>
    </div>
    <div class="col-lg-3 col-md-4 col-sm-6">
      <h4>YUMYUM BAKERY</h4>
      <ul>
        <li><a href="/about_us">About Us</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <div class="mt-sponsor">
        <h4>SPONSOR</h4>
        <div class="row g-2">
          <div class="col-6"><div class="sponsor-logo-box"><img src="/assets/logo/anchor.png" alt="Anchor" onerror="this.src='https://via.placeholder.com/100x40?text=Anchor'"></div></div>
          <div class="col-6"><div class="sponsor-logo-box"><img src="/assets/logo/indofood.png" alt="Indofood" onerror="this.src='https://via.placeholder.com/100x40?text=Indofood'"></div></div>
          <div class="col-6"><div class="sponsor-logo-box"><img src="/assets/logo/gofood.png" alt="GoFood" onerror="this.src='https://via.placeholder.com/100x40?text=GoFood'"></div></div>
          <div class="col-6"><div class="sponsor-logo-box"><img src="/assets/logo/tokped.png" alt="Tokopedia" onerror="this.src='https://via.placeholder.com/100x40?text=Tokopedia'"></div></div>
        </div>
      </div>
    </div>
    <div class="col-lg-2 col-md-4 col-sm-12 mt-4 mt-md-0">
      <h4>HELP CENTER</h4>
      <ul><li><a href="#">Privacy Policy</a></li></ul>
    </div>
    <div class="col-lg-4 col-md-12 mt-4 mt-lg-0">
      <h4>CONTACT US</h4>
      <div class="contact-item">
        <img src="/assets/icon/tlp.png" alt="phone" onerror="this.outerHTML='<span style=\'font-size:20px;\'>📞</span>'"/> 889070999
      </div>
      <div class="contact-item">
        <img src="/assets/icon/wa.png" alt="whatsapp" onerror="this.outerHTML='<span style=\'font-size:20px;\'>📱</span>'"/> +62 887 1447 0009
      </div>
      <div class="contact-item">
        <img src="/assets/icon/ig.png" alt="instagram" onerror="this.outerHTML='<span style=\'font-size:20px;\'>📸</span>'"/> @YumYum_Bakery
      </div>
      <div class="mt-pengaduan">
        <h4>LAYANAN PENGADUAN</h4>
        <div class="complaint-section">
          <p>PT Matahari Bulan Bintang Angkasa</p>
          <p>Email : marketing@yumyum.com</p>
          <p>0867 0000 1222 (WhatsApp)</p>
        </div>
      </div>
    </div>
  </div>
  <hr class="footer-divider"/>
  <p class="footer-bottom">© 2024 YumYum Bakery. All rights reserved.</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const API_BASE = 'http://localhost:3000/api';
  let allOrders = [];

  function formatRupiah(num) {
    return 'Rp ' + Number(num).toLocaleString('id-ID');
  }
  function formatDate(str) {
    return new Date(str).toLocaleDateString('id-ID', {
      day: '2-digit', month: 'long', year: 'numeric',
      hour: '2-digit', minute: '2-digit'
    });
  }

  async function loadHistory() {
    try {
      const res  = await fetch(`${API_BASE}/history`);
      const json = await res.json();
      if (!json.success || !json.data.length) { renderEmpty(); return; }
      allOrders = json.data;
      renderOrders(allOrders);
    } catch {
      document.getElementById('orderList').innerHTML = `
        <div class="state-msg">
          <p>Gagal memuat data. Pastikan server backend berjalan.</p>
        </div>`;
    }
  }

  function filterOrders() {
    const q = document.getElementById('customerSearch').value.toLowerCase();
    const filtered = allOrders.filter(o => o.customer_name.toLowerCase().includes(q));
    filtered.length ? renderOrders(filtered) : renderEmpty();
  }

  function renderEmpty() {
    document.getElementById('orderList').innerHTML = `
      <div class="state-msg">
        <div class="icon">📭</div>
        <p>Belum ada riwayat pesanan ditemukan.</p>
      </div>`;
  }

  function renderOrders(orders) {
    const container = document.getElementById('orderList');
    container.innerHTML = '';

    orders.forEach((order, i) => {
      const itemsHTML = (order.items || []).map(item => `
        <div class="item-row">
          <img class="item-img"
               src="${item.img_url || ''}"
               alt="${item.product_name}"
               onerror="this.src='https://images.unsplash.com/photo-1555507036-ab1f4038808a?w=100&h=100&fit=crop'"/>
          <span class="item-name">${item.product_name}</span>
          <span class="item-qty">x${item.quantity}</span>
          <span class="item-subtotal">${formatRupiah(item.subtotal)}</span>
        </div>
      `).join('');

      const card = document.createElement('div');
      card.className = 'order-card';
      card.style.animationDelay = `${i * 0.06}s`;
      card.innerHTML = `
        <div class="card-head">
          <div>
            <div class="order-title">Order #${order.order_id}</div>
            <div class="order-customer">${order.customer_name}</div>
          </div>
          <span class="badge-date">${formatDate(order.order_date)}</span>
        </div>
        <div class="card-body-inner">
          <div class="items-label">Detail Pesanan</div>
          ${itemsHTML || '<p style="color:#aaa;font-size:13px;">Tidak ada item.</p>'}
        </div>
        <div class="card-foot">
          <span class="total-label">Total Pembayaran</span>
          <span class="total-amount">${formatRupiah(order.total_amount)}</span>
        </div>
      `;
      container.appendChild(card);
    });
  }

  loadHistory();
</script>
</body>
</html>