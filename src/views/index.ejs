</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const API_BASE = 'http://localhost:3000/api';
  
  
  const HOME_MENU_TARGETS = [
    'Birthday cake', 
    'Caramel Macchiato', 
    'Macaron', 
    'Strawberry Danish', 
    'Cookies', 
    'Strawberry milk'
  ].map(name => name.toLowerCase());

  function formatRupiah(num) {
    return 'Rp ' + Number(num).toLocaleString('id-ID');
  }

  function renderSkeletons() {
    const grid = document.getElementById('productsGrid');
    grid.innerHTML = Array(6).fill(`
      <div class="col-lg-4 col-md-6">
        <div class="skeleton-card">
          <div class="skeleton-img"></div>
          <div class="skeleton-text"></div>
          <div class="skeleton-text short"></div>
        </div>
      </div>
    `).join('');
  }

  async function fetchHomePageProducts() {
    renderSkeletons();
    try {
      const res  = await fetch(`${API_BASE}/menu`);
      const json = await res.json();

      if (!json.success) throw new Error(json.message);

      
      const displayProducts = json.data.filter(p => 
        HOME_MENU_TARGETS.includes(p.name.toLowerCase())
      );

      renderProducts(displayProducts);
    } catch (err) {
      document.getElementById('productsGrid').innerHTML = `
        <div class="col-12 text-center py-5">
          <p>Gagal memuat produk. Pastikan server backend berjalan.</p>
        </div>`;
    }
  }

  function renderProducts(products) {
    const grid = document.getElementById('productsGrid');
    
    grid.innerHTML = products.map(p => `
      <div class="col-lg-4 col-md-6">
        <div class="product-card">
          <img src="${p.img_url || ''}" alt="${p.name}"
               onerror="this.src='https://images.unsplash.com/photo-1555507036-ab1f4038808a?w=400&h=400&fit=crop'" />
          <div class="product-card-info">
            <p class="sub-cat-label">${p.sub_category} · ${p.category}</p>
            <h3>${p.name}</h3>
            <p class="price">${formatRupiah(p.price)}</p>
            <a href="/menu/${p.id}" class="btn-add-card">+ Tambah ke Keranjang</a>
          </div>
        </div>
      </div>
    `).join('');

    
    document.getElementById('seeMoreWrap').style.display = 'block';
  }
  
  fetchHomePageProducts();
  
async function addToCart(productId, event) {

  if (event) {
    event.preventDefault();
    event.stopPropagation();
  }

  try {
    const response = await fetch('http://localhost:3000/cart', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ product_id: productId, quantity: 1 })
    });
    
    if (response.ok) {
      alert("Produk berhasil ditambahkan ke keranjang!");
    } else {
      alert("Gagal menambahkan produk ke keranjang.");
    }
  } catch (error) {
    console.error("Gagal memproses keranjang:", error);
  }
}

  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
      
      searchInput.addEventListener('keypress', function (e) {
        if (e.key === 'Enter') {
          e.preventDefault();
          const keyword = this.value.trim();
          if (keyword) {
            
            window.location.href = `/menu?search=${encodeURIComponent(keyword)}`;
          }
        }
      });
    }
  });

</script>

</body>
</html>