<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= locals.pageTitle || 'About Us — YumYum Bakery' %></title>

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>

  <link href="/css/about_us.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/index.css">

</head>
<body>

  <%- include('navbar') %>

<div id="loader" class="text-center py-5 mt-5">
  <div class="spinner-border text-secondary" role="status"></div>
  <p class="mt-3 text-muted">Memuat informasi...</p>
</div>

<div class="about-main-container" id="about-container" style="display: none;">
  
  <div class="about-header">
    <div class="about-header-line"></div>
    <h1>About Us</h1>
    <div class="about-header-line"></div>
  </div>

  <div class="about-banner" id="render-banner">
    <div class="banner-quote" id="render-quote"></div>
  </div>

  <div class="row">
    <div class="col-lg-7 pe-lg-5" id="render-paragraphs">
      </div>
    
    <div class="col-lg-5 mt-4 mt-lg-0">
      <img id="render-side-image" src="" alt="YumYum Bakery Pastry" class="about-side-img" />
    </div>
  </div>

</div>

<%- include('footer') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const API_BASE = 'http://localhost:3000';

  const fallbackAboutData = {
    banner_img: "/gambar/about us banner.jpg",
    quote: "Created with love and passion for French patisserie, YUMYUM is today's largest European-style bakery & pastry shop chain in Indonesia",
    paragraphs: [
      "Sejak pertama kali menyalakan oven kami, YUMYUM BAKERY hadir membawa kehangatan cita rasa roti khas dunia untuk keluarga di Indonesia. Kini, dengan puluhan gerai yang tersebar luas, fokus kami tetap sama: menyajikan kualitas tanpa kompromi dan senyuman di setiap kunjungan pelanggan.",
      "Bagi kami, setiap adonan adalah seni yang terus berkembang. Kami tumbuh melalui dedikasi terhadap bahan alami, kemasan yang estetik, dan pelayanan yang penuh perhatian. Inovasi adalah nyawa kami, dan setiap kemitraan yang kami lakukan bertujuan untuk selalu memanjakan lidah pelanggan setia kami.",
      "Memasuki fase baru di tahun ini, kami bangga memperkenalkan wajah baru korporasi kami sebagai PT Yumyum Sentra Boga. Transisi ini bukan sekadar perubahan nama, melainkan janji kami untuk membawa YUMYUM BAKERY ke level yang lebih tinggi, memberikan kualitas terbaik yang layak Anda dapatkan."
    ],
    side_img: "/gambar/about us kue.png"
  };

  async function fetchAboutData() {
    try {
      const response = await fetch(`${API_BASE}/about`);
      const json = await response.json();
      
      if (json.success && json.data) {
        renderAboutUI(json.data);
      } else {
        throw new Error("Gagal mengambil data, menggunakan fallback.");
      }
    } catch (error) {
      renderAboutUI(fallbackAboutData);
    }
  }

  function renderAboutUI(data) {
    document.getElementById('loader').style.display = 'none';
    document.getElementById('about-container').style.display = 'block';

    const banner = document.getElementById('render-banner');
    banner.style.backgroundImage = `url('${data.banner_img}')`;
    document.getElementById('render-quote').textContent = data.quote;

    const textContainer = document.getElementById('render-paragraphs');
    textContainer.innerHTML = data.paragraphs.map(p => `<p class="about-text">${p}</p>`).join('');

    const sideImg = document.getElementById('render-side-image');
    sideImg.src = data.side_img;
    sideImg.onerror = function() {
      this.src = 'https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=800&fit=crop';
    };
  }

  document.addEventListener('DOMContentLoaded', () => {
    fetchAboutData();

  });
</script>
</body>
</html>