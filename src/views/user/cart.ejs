<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Cart — YumYum Bakery</title>

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>

  <style>
    :root {
      --navbar-bg:   #4E2609;
      --footer-bg:   #4E2609;
      --cart-btn:    #754C27;
      --cream:       #f5f0e8;
      --brown-dark:  #3b1f0e;
      --brown-mid:   #5c2d0e;
      --brown-light: #8b4513;
      --gold:        #c9922a;
      --gold-light:  #e8b84b;
      --white:       #fff;
      --text-dark:   #2b1a0a;
      --text-gray:   #666;
    }

    body {
      font-family: 'Poppins', sans-serif;
      background: var(--cream);
      color: var(--text-dark);
      min-height: 100vh;
    }

    .navbar {
      background: var(--navbar-bg) !important;
      padding: 10px 48px;
      box-shadow: 0 3px 16px rgba(0,0,0,0.3);
    }

    .nav-logo-img { height: 50px; width: auto; object-fit: contain; }

    .nav-logo-fallback { display: flex; align-items: center; gap: 10px; }
    .nav-logo-fallback .logo-box {
      width: 48px; height: 48px;
      background: var(--cart-btn);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
    }
    .nav-logo-fallback .brand-name {
      font-family: 'Playfair Display', serif;
      font-weight: 700;
    }
    .nav-logo-fallback .brand-sub {
      letter-spacing: 2px;
      text-transform: uppercase;
      font-size: 11px;
    }

    .navbar-nav .nav-link {
      font-family: 'Poppins', sans-serif;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #fff;
    }
    .navbar-nav .nav-link:hover { color: var(--gold-light) !important; }

    .btn-cart {
      background: var(--cart-btn); color: #fff; border: none;
      padding: 10px 22px; border-radius: 8px; font-family: 'Marmelad', sans-serif;
      font-size: 15px; cursor: pointer; display: flex; align-items: center; gap: 8px;
      box-shadow: 0 4px 18px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.18);
      transition: background 0.2s, transform 0.15s;
    }
    .btn-cart:hover { background: #8a5c30; transform: translateY(-1px); }
    .btn-cart img { width: 20px; height: 20px; filter: brightness(0) invert(1); }

    .cart-badge {
      position: absolute;
      top: -8px; right: -8px;
      background: #e74c3c;
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      width: 20px; height: 20px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      display: none;
    }

    .search-wrapper {
      position: relative;
      display: flex;
      align-items: center;
    }
    #searchInput {
      width: 0;
      opacity: 0;
      padding: 0;
      border: none;
      outline: none;
      background: rgba(255,255,255,0.15);
      color: #fff;
      font-family: 'Poppins', sans-serif;
      font-size: 13px;
      border-radius: 8px;
      transition: width 0.35s ease, opacity 0.35s ease, padding 0.35s ease;
    }
    #searchInput::placeholder { color: rgba(255,255,255,0.6); }
    #searchInput.open {
      width: 200px;
      opacity: 1;
      padding: 8px 14px;
      margin-right: 8px;
    }

    .btn-search {
      background: rgba(255,255,255,0.42); backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,0.35); width: 44px; height: 44px;
      border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center;
      box-shadow: 0 4px 14px rgba(0,0,0,0.25); transition: background 0.2s;
    }
    .btn-search:hover { background: rgba(255,255,255,0.6); }
    .btn-search img { width: 20px; height: 20px; }

    .page-header { text-align: center; padding: 28px 48px 20px; border-bottom: 1px solid #e0d8cd; background: #fff; }
    .page-title { font-family: 'Playfair Display', serif; font-size: 24px; font-weight: 700; color: var(--text-dark); margin-top: 8px; letter-spacing: 1px; }

    .cart-wrapper { max-width: 900px; margin: 40px auto; padding: 0 24px 80px; }
    .btn-back { display: inline-flex; align-items: center; gap: 8px; color: var(--text-gray); text-decoration: none; font-size: 14px; margin-bottom: 24px; font-weight: 500; }
    .btn-back:hover { color: var(--brown-dark); }

    .input-section { background: #fff; border-radius: 12px; padding: 20px 24px; margin-bottom: 24px; border: 1px solid #ebebeb; }
    .input-section label { font-weight: 600; font-size: 14px; margin-bottom: 8px; display: block; }
    .input-section input { width: 100%; padding: 12px 16px; border-radius: 8px; border: 1px solid #ddd; outline: none; font-family: 'Poppins', sans-serif; }
    .input-section input:focus { border-color: var(--brown-dark); }

    .cart-card { background: #fff; border-radius: 12px; border: 1px solid #ebebeb; padding: 16px; display: flex; align-items: center; gap: 20px; height: 100%; transition: box-shadow 0.2s; }
    .cart-card:hover { box-shadow: 0 4px 14px rgba(0,0,0,0.03); }
    .cart-card img { width: 100px; height: 100px; object-fit: cover; border-radius: 10px; flex-shrink: 0; }
    .cart-info { flex-grow: 1; }
    .cart-info h5 { font-family: 'Playfair Display', serif; font-size: 20px; font-weight: 700; margin: 0 0 4px; color: var(--text-dark); }
    .cart-info p { font-family: 'Poppins', sans-serif; font-size: 15px; color: var(--text-dark); font-weight: 600; margin: 0 0 12px; }
    
    .qty-box { display: inline-flex; align-items: center; border: 1px solid #ddd; border-radius: 25px; padding: 4px 12px; background: #fff; }
    .qty-box button { background: none; border: none; font-size: 18px; font-weight: 500; color: var(--text-dark); cursor: pointer; padding: 0 8px; transition: transform 0.1s; }
    .qty-box button:active { transform: scale(0.9); }
    .qty-box span { margin: 0 12px; font-weight: 600; font-size: 15px; min-width: 20px; text-align: center; }

    .empty-state { text-align: center; padding: 60px 20px; background: #fff; border-radius: 12px; border: 1px solid #ebebeb; }
    .empty-state h3 { font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 700; margin-bottom: 12px; }
    .btn-shop-now { display: inline-block; background: var(--brown-dark); color: #fff; padding: 10px 32px; border-radius: 25px; text-decoration: none; font-weight: 600; font-size: 14px; margin-top: 10px; transition: background 0.2s; }
    .btn-shop-now:hover { background: #251206; color: #fff; }

    .cart-summary { background: #fff; border-radius: 12px; padding: 24px; margin-top: 24px; border: 1px solid #ebebeb; }
    .btn-order { width: 100%; background: var(--brown-dark); color: #fff; border: none; border-radius: 25px; padding: 12px; font-weight: 600; cursor: pointer; transition: background 0.2s; font-size: 15px; }
    .btn-order:hover { background: #251206; }
    .btn-reset { width: 100%; background: transparent; color: var(--text-dark); border: 1.5px solid var(--text-dark); border-radius: 25px; padding: 12px; margin-top: 12px; font-weight: 600; cursor: pointer; transition: all 0.2s; font-size: 15px; }
    .btn-reset:hover { background: #f9f9f9; }

    footer {
      background: var(--footer-bg); color: rgba(255,255,255,0.9);
      padding: 60px 48px 30px; font-family: 'Poppins', sans-serif;
    }

    .footer-logo-main {
      width: 100%; max-width: 220px; border: 1.5px solid #dcb786;
      padding: 8px; margin-bottom: 30px; object-fit: contain;
    }
    .footer-halal { width: 85px; height: 85px; object-fit: contain; }

    footer h4 {
      font-family: 'Poppins', sans-serif;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #fff;
      margin-bottom: 14px;
    }

    footer ul { list-style: none; padding: 0; margin: 0; }
    footer ul li { margin-bottom: 8px; }
    footer ul li a {
      text-decoration: none;
      color: rgba(255,255,255,0.7);
      font-size: 13px;
      transition: color 0.2s;
    }
    footer ul li a:hover { color: var(--gold-light); }

    .contact-item {
      display: flex; align-items: center; gap: 10px;
      color: rgba(255,255,255,0.8); font-size: 13px; margin-bottom: 10px;
    }
    .contact-item img {
      width: 20px; height: 20px; object-fit: contain;
      filter: brightness(0) invert(1); opacity: 0.85;
    }

    .mt-sponsor { margin-top: 32px; }

    .sponsor-logo-box {
      background: #fff; border-radius: 8px; padding: 8px 10px;
      display: flex; align-items: center; justify-content: center;
      height: 40px; overflow: hidden;
    }
    .sponsor-logo-box img { max-width: 100%; max-height: 20px; object-fit: contain; }

    .mt-pengaduan { margin-top: 32px; }
    .complaint-section p { font-size: 12px; color: rgba(255,255,255,0.7); line-height: 1.8; margin-bottom: 0; }

    .footer-divider { border: none; border-top: 1px solid rgba(255,255,255,0.15); margin: 40px 0 16px; }
    .footer-bottom { text-align: center; font-size: 12px; color: rgba(255,255,255,0.4); }

    @media (max-width: 992px) {
      .navbar { padding: 10px 20px; } .hero-wrapper { padding: 30px 20px 60px; }
      .hero-slide { aspect-ratio: 16 / 7; } .products-grid-section, .category-tabs { padding: 16px 20px; }
      .reviews-section { padding: 40px 20px 60px; } footer { padding: 40px 20px 20px; }
    }
  </style>
</head>
<body>

<nav class="navbar navbar-expand-lg sticky-top">
  <div class="container-fluid px-0">
    <a class="navbar-brand ms-0" href="/index">
      <img src="/assets/logo/logo_nama.png" alt="YumYum Bakery" class="nav-logo-img"
           onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
      <div class="nav-logo-fallback" style="display:none;">
        <div class="logo-box">
          <svg viewBox="0 0 48 48" fill="none" width="32" height="32">
            <ellipse cx="24" cy="28" rx="16" ry="10" fill="#c9922a"/>
            <ellipse cx="24" cy="26" rx="14" ry="8" fill="#e8b84b"/>
            <path d="M16 18 Q24 10 32 18" stroke="#c9922a" stroke-width="2.5" fill="none" stroke-linecap="round"/>
            <text x="15" y="33" font-size="9" font-weight="bold" fill="#3b1f0e" font-family="serif">YB</text>
          </svg>
        </div>
        <div>
          <span class="brand-name" style="color:#fff">YumYum</span>
          <span class="brand-sub d-block" style="color:rgba(255,255,255,0.7)">Bakery</span>
        </div>
      </div>
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarMain">
      <ul class="navbar-nav mx-auto">
        <li class="nav-item"><a class="nav-link" href="/menu">MENU</a></li>
        <li class="nav-item"><a class="nav-link" href="/store">STORE</a></li>
        <li class="nav-item"><a class="nav-link" href="/about_us">ABOUT US</a></li>
        <li class="nav-item"><a class="nav-link" href="/history">HISTORY</a></li>
      </ul>
      <div class="d-flex align-items-center gap-3 mt-2 mt-lg-0">
        <a href="/cart" class="btn-cart">
          <img src="/assets/icon/keranjang.png" alt="Cart"> CART
          <span class="cart-badge" id="cartBadge">0</span>
        </a>
      </div>
    </div>
  </div>
</nav>

<div class="page-header">
  <div class="page-title">CART</div>
</div>

<div class="cart-wrapper">
  <a href="/" class="btn-back">← Kembali ke Beranda</a>

  <div class="input-section">
    <label for="customer-name">Nama Pemesan <span style="color:red">*</span></label>
    <input type="text" id="customer-name" placeholder="Masukkan nama kamu di sini..." required />
  </div>

  <div id="cart-container">
    <div class="text-center py-5">Memuat data keranjang...</div>
  </div>

  <div class="cart-summary" id="cart-summary" style="display: none;">
    <div class="d-flex justify-content-between mb-4 fs-5 fw-bold" style="font-family: 'Poppins', sans-serif;">
      <span>Total Harga</span>
      <span id="total-price">Rp 0</span>
    </div>
    <button id="btn-order" class="btn-order">Purchase Now</button>
    <button id="btn-reset" class="btn-reset">Reset</button>
  </div>
</div>

<div class="modal fade" id="receiptModal" data-bs-backdrop="static" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content p-4">
      <div class="text-center">
        <h4 class="fw-bold" style="font-family: 'Playfair Display', serif;">YumYum Bakery</h4>
        <p class="text-muted small mb-1">Struk Pembelian Terkonfirmasi</p>
        <p class="text-muted small fw-bold" id="r-customerName"></p>
        <hr style="border-top: 2px dashed #bbb;">
      </div>
      
      <div id="r-items-container" class="mb-3">
        </div>
      
      <hr style="border-top: 2px dashed #bbb;">
      <div class="d-flex justify-content-between fw-bold mt-2" style="font-size: 18px;">
        <span>TOTAL</span>
        <span id="r-total">Rp 0</span>
      </div>
      
      <button class="btn btn-dark w-100 mt-4 rounded-pill" onclick="window.location.href='/'">Kembali ke Beranda</button>
    </div>
  </div>
</div>

<footer>
  <div class="row g-4 mb-4">
    <div class="col-lg-3 col-md-4 col-sm-6">
      <div class="d-flex flex-column align-items-start">
        <img src="/assets/logo/logo_aja.png" alt="YumYum Bakery Logo" class="footer-logo-main"
             onerror="this.src='https://via.placeholder.com/200x100?text=YumYum+Logo'"/>
        <img src="/assets/icon/icon halal.png" alt="Halal" class="footer-halal"
             onerror="this.src='https://via.placeholder.com/80?text=Halal'"/>
      </div>
    </div>

    <div class="col-lg-3 col-md-4 col-sm-6">
      <h4>YUMYUM BAKERY</h4>
      <ul>
        <li><a href="/about_us">About Us</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <div class="mt-sponsor">
        <h4>SPONSOR</h4>
        <div class="row g-2">
          <div class="col-6"><div class="sponsor-logo-box"><img src="/assets/logo/anchor.png" alt="Anchor" onerror="this.src='https://via.placeholder.com/100x40?text=Anchor'"></div></div>
          <div class="col-6"><div class="sponsor-logo-box"><img src="/assets/logo/indofood.png" alt="Indofood" onerror="this.src='https://via.placeholder.com/100x40?text=Indofood'"></div></div>
          <div class="col-6"><div class="sponsor-logo-box"><img src="/assets/logo/gofood.png" alt="GoFood" onerror="this.src='https://via.placeholder.com/100x40?text=GoFood'"></div></div>
          <div class="col-6"><div class="sponsor-logo-box"><img src="/assets/logo/tokped.png" alt="Tokopedia" onerror="this.src='https://via.placeholder.com/100x40?text=Tokopedia'"></div></div>
        </div>
      </div>
    </div>

    <div class="col-lg-2 col-md-4 col-sm-12 mt-4 mt-md-0">
      <h4>HELP CENTER</h4>
      <ul>
        <li><a href="/privacy">Privacy Policy</a></li>
      </ul>
    </div>

    <div class="col-lg-4 col-md-12 mt-4 mt-lg-0">
      <h4>CONTACT US</h4>
      <div class="contact-item">
        <img src="/assets/icon/tlp.png" alt="phone" onerror="this.outerHTML='<span style=\'font-size:20px;\'>📞</span>'" /> 889070999
      </div>
      <div class="contact-item">
        <img src="assets/icon/wa.png" alt="whatsapp" onerror="this.outerHTML='<span style=\'font-size:20px;\'>📱</span>'" /> +62 887 1447 0009
      </div>
      <div class="contact-item">
        <img src="/assets/icon/ig.png" alt="instagram" onerror="this.outerHTML='<span style=\'font-size:20px;\'>📸</span>'" /> @YumYum_Bakery
      </div>
      <div class="mt-pengaduan">
        <h4>LAYANAN PENGADUAN</h4>
        <div class="complaint-section">
          <p>PT Matahari Bulan Bintang Angkasa</p>
          <p>Email : marketing@yumyum.com</p>
          <p>0867 0000 1222 (WhatsApp)</p>
        </div>
      </div>
    </div>
  </div>

  <hr class="footer-divider"/>
  <p class="footer-bottom">© 2024 YumYum Bakery. All rights reserved.</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
  const API_BASE = 'http://localhost:3000/api';
  let cartItems = [];
  let currentTotalPrice = 0;

  function formatRupiah(num) {
    return 'Rp ' + Number(num).toLocaleString('id-ID');
  }

  function loadCartData() {
    cartItems = JSON.parse(localStorage.getItem('yumyum_cart')) || [];
    renderCart();
  }

  window.updateCartQty = function(productId, change) {
    let cart = JSON.parse(localStorage.getItem('yumyum_cart')) || [];
    const itemIndex = cart.findIndex(i => i.product_id === productId);
    
    if (itemIndex > -1) {
      cart[itemIndex].quantity += change;
      
      if (cart[itemIndex].quantity <= 0) {
        cart.splice(itemIndex, 1);
      }
      
      localStorage.setItem('yumyum_cart', JSON.stringify(cart));
      loadCartData(); // Render ulang tampilan
    }
  };

  function renderCart() {
    const container = document.getElementById('cart-container');
    const summary = document.getElementById('cart-summary');
    const totalEl = document.getElementById('total-price');
    
    if (cartItems.length === 0) {
      container.innerHTML = `
        <div class="empty-state">
          <h3>KERANJANG KOSONG!</h3>
          <p style="color: var(--text-gray); margin-bottom: 24px;">Kamu belum memilih menu apapun.</p>
          <a href="/" class="btn-shop-now">Shop Now</a>
        </div>
      `;
      summary.style.display = 'none';
      return;
    }

    summary.style.display = 'block';
    currentTotalPrice = 0;
    
    container.innerHTML = '<div class="row g-4">' + cartItems.map(item => {
      const qty = item.quantity || 1; 
      const subtotal = Number(item.price) * qty;
      currentTotalPrice += subtotal;

      return `
        <div class="col-md-6">
          <div class="cart-card">
            <img src="${item.img_url}" alt="${item.name}" onerror="this.src='https://via.placeholder.com/100'" />
            <div class="cart-info">
              <h5>${item.name}</h5>
              <p>${formatRupiah(item.price)}</p>
              <div class="qty-box">
                <button onclick="updateCartQty(${item.product_id}, -1)">−</button>
                <span>${qty}</span>
                <button onclick="updateCartQty(${item.product_id}, 1)">+</button>
              </div>
            </div>
          </div>
        </div>
      `;
    }).join('') + '</div>';

    totalEl.textContent = formatRupiah(currentTotalPrice);
  }

  document.getElementById('btn-order').addEventListener('click', async () => {
    const customerName = document.getElementById('customer-name').value.trim();

    if (!customerName) {
      alert("Silakan masukkan Nama Pemesan terlebih dahulu!");
      return;
    }

    const orderPayload = {
      customer_name: customerName,
      total_price: currentTotalPrice,
      items: cartItems.map(item => ({
        menu_id: item.product_id,
        qty: item.quantity
      }))
    };

    try {
      const res = await fetch(`${API_BASE}/order`, { 
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(orderPayload)
      });
      
      const json = await res.json();
      
      if (json.success) {
        document.getElementById('r-customerName').textContent = "Pelanggan: " + customerName;
        
        const receiptItemsContainer = document.getElementById('r-items-container');
        receiptItemsContainer.innerHTML = cartItems.map(item => `
          <div class="d-flex justify-content-between mb-2" style="font-size: 14px;">
            <span>${item.name} x${item.quantity || 1}</span>
            <span>${formatRupiah(item.price * (item.quantity || 1))}</span>
          </div>
        `).join('');
        
        document.getElementById('r-total').textContent = formatRupiah(currentTotalPrice);

        const receiptModal = new bootstrap.Modal(document.getElementById('receiptModal'));
        receiptModal.show();

        localStorage.removeItem('yumyum_cart');

      } else {
        alert("Gagal memproses pesanan: " + json.message);
      }
    } catch (err) {
      console.error("Error Checkout:", err);
      alert("Gagal terhubung ke server. Pastikan backend sudah menyala.");
    }
  });

  document.getElementById('btn-reset').addEventListener('click', () => {
  const confirmReset = confirm("Yakin ingin mengosongkan keranjang?");
  
  if (confirmReset) {
    localStorage.removeItem('yumyum_cart');
    loadCartData();
  }
});

  loadCartData();
</script>
</body>
</html>