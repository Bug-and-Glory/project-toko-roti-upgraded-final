<% const base=locals.baseUrl ? locals.baseUrl : '' ; %>
  <!DOCTYPE html>
  <html lang="en">

  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      <%= title || 'Comment - YumYum Bakery' %>
    </title>

    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap"
      rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link href="/css/index.css" rel="stylesheet" />
    <link href="/css/contact.css" rel="stylesheet" />

  </head>

  <body>

    <nav class="navbar navbar-expand-lg sticky-top">
      <div class="container-fluid px-0">
        <a class="navbar-brand ms-0" href="/">
          <img src="/logo/logo_nama.png" alt="YumYum Bakery" class="nav-logo-img"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
          <div class="nav-logo-fallback" style="display:none;">
            <div class="logo-box">
              <svg viewBox="0 0 48 48" fill="none" width="32" height="32">
                <ellipse cx="24" cy="28" rx="16" ry="10" fill="#c9922a" />
                <ellipse cx="24" cy="26" rx="14" ry="8" fill="#e8b84b" />
                <path d="M16 18 Q24 10 32 18" stroke="#c9922a" stroke-width="2.5" fill="none" stroke-linecap="round" />
                <text x="15" y="33" font-size="9" font-weight="bold" fill="#3b1f0e" font-family="serif">YB</text>
              </svg>
            </div>
            <div>
              <span class="brand-name" style="color:#fff">YumYum</span>
              <span class="brand-sub d-block" style="color:rgba(255,255,255,0.7)">Bakery</span>
            </div>

          </div>
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
          <ul class="navbar-nav mx-auto">
            <li class="nav-item"><a class="nav-link" href="menu">MENU</a></li>
            <li class="nav-item"><a class="nav-link" href="/store">STORE</a></li>
            <li class="nav-item"><a class="nav-link" href="about_us">ABOUT US</a></li>
            <li class="nav-item"><a class="nav-link" href="/history">HISTORY</a></li>
          </ul>
          <div class="d-flex align-items-center gap-3 mt-2 mt-lg-0">

            <a href="/cart" class="btn-cart-navbar">
              <span>CART</span>
              <img src="/icon/keranjang.png" alt="Cart">
            </a>

            <% if (typeof user !=="undefined" && user) { %>
              <details class="user-navbar-menu">
                <summary class="btn-user-navbar">
                  <%= user.username %>
                </summary>

                <div class="user-navbar-dropdown">
                  <a href="/logout">LOGOUT</a>
                </div>
              </details>
              <% } else { %>
                <a href="/login" class="btn-login-navbar">
                  LOGIN/SIGN UP
                </a>
                <% } %>

          </div>
        </div>
      </div>
    </nav>

    <div class="section-heading">
      <p class="celebrate">Share Your Experience</p>
      <h2>KOMENTAR & SARAN</h2>
      <p class="sub-title">- CERITAKAN PENGALAMAN KAMU -</p>
    </div>

    <div class="contact-wrapper">
      <div class="contact-card row g-0">

        <div class="col-lg-5 contact-info-side">
          <h3>Bagikan Komentar Kamu</h3>
          <p>Kami senang mendengar pengalaman kamu setelah mencoba produk YumYum Bakery. Komentar dan saran kamu akan
            membantu kami meningkatkan kualitas produk dan pelayanan.</p>

          <div class="info-item">
            <div class="icon-circle">
              <img src="/icon/tlp.png" alt="phone" onerror="this.outerHTML='📞'" />
            </div>
            <div>
              <h5>Telepon</h5>
              <span>889070999</span>
            </div>
          </div>

          <div class="info-item">
            <div class="icon-circle">
              <img src="/icon/wa.png" alt="whatsapp" onerror="this.outerHTML='📱'" />
            </div>
            <div>
              <h5>WhatsApp</h5>
              <span>+62 887 1447 0009</span>
            </div>
          </div>

          <div class="info-item">
            <div class="icon-circle">
              <img src="/icon/ig.png" alt="instagram" onerror="this.outerHTML='@'" />
            </div>
            <div>
              <h5>Email & Sosial Media</h5>
              <span>marketing@yumyum.com<br>@YumYum_Bakery</span>
            </div>
          </div>
        </div>

        <div class="col-lg-7 contact-form-side">

          <% if (message) { %>
            <div class="alert alert-info mb-3">
              <%= message %>
            </div>
            <% } %>

              <form action="/comment" method="POST" id="contactForm">

                <div class="mb-3">
                  <label for="name" class="form-label">Nama Lengkap</label>
                  <input type="text" class="form-control" id="name" value="<%= user.name || user.username %>" readonly>
                </div>

                <div class="mb-3">
                  <label for="email" class="form-label">Alamat Email</label>
                  <input type="email" class="form-control" id="email" value="<%= user.email %>" readonly>
                </div>

                <div class="mb-4">
                  <label for="comment" class="form-label">Komentar Anda</label>
                  <textarea class="form-control" id="comment" name="comment" rows="5"
                    placeholder="Tuliskan komentar kamu di sini..." required></textarea>
                </div>

                <% if (message) { %>
                  <div class="alert alert-info">
                    <%= message %>
                  </div>
                  <% } %>

                    <button type="submit" class="btn-submit" id="btnSubmit">
                      KIRIM KOMENTAR
                    </button>

                    <a href="/showComments" class="btn-lihat-komentar">
                      LIHAT KOMENTAR
                    </a>

              </form>
        </div>

      </div>
    </div>

    <footer>
      <div class="row g-4 mb-4">
        <div class="col-lg-3 col-md-4 col-sm-6">
          <div class="d-flex flex-column align-items-start">
            <img src="/logo/logo_aja.png" alt="YumYum Bakery Logo" class="footer-logo-main"
              onerror="this.src='https://via.placeholder.com/200x100?text=YumYum+Logo'" />
            <img src="/icon/icon halal.png" alt="Halal" class="footer-halal"
              onerror="this.src='https://via.placeholder.com/80?text=Halal'" />
          </div>
        </div>

        <div class="col-lg-3 col-md-4 col-sm-6">
          <h4>YUMYUM BAKERY</h4>
          <ul>
            <li><a href="/aboutUs">About Us</a></li>
            <li><a href="/comment">Comment</a></li>
          </ul>
          <div class="mt-sponsor">
            <h4>SPONSOR</h4>
            <div class="row g-2">
              <div class="col-6">
                <div class="sponsor-logo-box"><img src="/logo/anchor.png" alt="Anchor"
                    onerror="this.src='https://via.placeholder.com/100x40?text=Anchor'"></div>
              </div>
              <div class="col-6">
                <div class="sponsor-logo-box"><img src="/logo/indofood.png" alt="Indofood"
                    onerror="this.src='https://via.placeholder.com/100x40?text=Indofood'"></div>
              </div>
              <div class="col-6">
                <div class="sponsor-logo-box"><img src="/logo/gofood.png" alt="GoFood"
                    onerror="this.src='https://via.placeholder.com/100x40?text=GoFood'"></div>
              </div>
              <div class="col-6">
                <div class="sponsor-logo-box"><img src="/logo/tokped.png" alt="Tokopedia"
                    onerror="this.src='https://via.placeholder.com/100x40?text=Tokopedia'"></div>
              </div>
            </div>
          </div>
        </div>

        <div class="col-lg-2 col-md-4 col-sm-12 mt-4 mt-md-0">
          <h4>HELP CENTER</h4>
          <ul>
            <li><a href="/privacy">Privacy Policy</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>

        <div class="col-lg-4 col-md-12 mt-4 mt-lg-0">
          <h4>CONTACT US</h4>
          <div class="contact-item">
            <img src="/icon/tlp.png" alt="phone" onerror="this.outerHTML='<span style=\'font-size:20px;\'>📞</span>'" />
            889070999
          </div>
          <div class="contact-item">
            <img src="/icon/wa.png" alt="whatsapp"
              onerror="this.outerHTML='<span style=\'font-size:20px;\'>📱</span>'" /> +62 887 1447 0009
          </div>
          <div class="contact-item">
            <img src="/icon/ig.png" alt="instagram"
              onerror="this.outerHTML='<span style=\'font-size:20px;\'>📸</span>'" /> @YumYum_Bakery
          </div>
          <div class="mt-pengaduan">
            <h4>LAYANAN PENGADUAN</h4>
            <div class="complaint-section">
              <p>PT Matahari Bulan Bintang Angkasa</p>
              <p>Email : marketing@yumyum.com</p>
              <p>0867 0000 1222 (WhatsApp)</p>
            </div>
          </div>
        </div>
      </div>

      <hr class="footer-divider" />
      <p class="footer-bottom">© 2024 YumYum Bakery. All rights reserved.</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const searchInput = document.getElementById('searchInput');
        if (searchInput) {
          searchInput.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
              e.preventDefault();
              const keyword = this.value.trim();
              if (keyword) window.location.href = `/menu?search=${encodeURIComponent(keyword)}`;
            }
          });
        }
      });

    </script>

  </body>

  </html>