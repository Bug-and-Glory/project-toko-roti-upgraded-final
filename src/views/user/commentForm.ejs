<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title><%= title || "Comment - YumYum Bakery" %></title>

  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />

  <link href="/css/index.css" rel="stylesheet" />
  <link href="/css/commentForm.css" rel="stylesheet" />
</head>

<body>

  <%- include("./navbar") %>

  <main>
    <div class="section-heading">
      <p class="celebrate">Share Your Experience</p>
      <h2>KOMENTAR & SARAN</h2>
      <p class="sub-title">- CERITAKAN PENGALAMAN KAMU -</p>
    </div>

    <div class="contact-wrapper">
      <div class="contact-card row g-0">

        <div class="col-lg-5 contact-info-side">
          <h3>Bagikan Komentar Kamu</h3>

          <p>
            Kami senang mendengar pengalaman kamu setelah mencoba produk YumYum Bakery.
            Komentar dan saran kamu akan membantu kami meningkatkan kualitas produk
            dan pelayanan.
          </p>

          <div class="info-item">
            <div class="icon-circle">
              <img src="/icon/tlp.png" alt="phone" />
            </div>
            <div>
              <h5>Telepon</h5>
              <span>889070999</span>
            </div>
          </div>

          <div class="info-item">
            <div class="icon-circle">
              <img src="/icon/wa.png" alt="whatsapp" />
            </div>
            <div>
              <h5>WhatsApp</h5>
              <span>+62 887 1447 0009</span>
            </div>
          </div>

          <div class="info-item">
            <div class="icon-circle">
              <img src="/icon/ig.png" alt="instagram" />
            </div>
            <div>
              <h5>Email & Sosial Media</h5>
              <span>marketing@yumyum.com<br>@YumYum_Bakery</span>
            </div>
          </div>
        </div>

        <div class="col-lg-7 contact-form-side">

          <% if (typeof message !== "undefined" && message) { %>
            <div class="alert alert-info mb-3">
              <%= message %>
            </div>
          <% } %>

          <form action="/comment" method="POST" id="commentForm">

            <div class="mb-3">
              <label for="name" class="form-label">Nama Lengkap</label>
              <input
                type="text"
                class="form-control"
                id="name"
                value="<%= user.name || user.username %>"
                readonly
              />
            </div>

            <div class="mb-3">
              <label for="email" class="form-label">Alamat Email</label>
              <input
                type="email"
                class="form-control"
                id="email"
                value="<%= user.email %>"
                readonly
              />
            </div>

            <div class="mb-4">
              <label for="comment" class="form-label">Komentar Anda</label>
              <textarea
                class="form-control"
                id="comment"
                name="comment"
                rows="5"
                placeholder="Tuliskan komentar kamu di sini..."
                required
              ></textarea>
            </div>

            <button type="submit" class="btn-submit">
              KIRIM KOMENTAR
            </button>

            <a href="/showComments" class="btn-lihat-komentar">
              LIHAT KOMENTAR
            </a>

          </form>
        </div>

      </div>
    </div>
  </main>

  <%- include("./footer") %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>