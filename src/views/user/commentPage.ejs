<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const API_BASE = 'http://localhost:3000/api';
  const COMMENTS_ENDPOINT = `${API_BASE}/comments`;

  function showToast(msg, duration = 2500) {
    const t = document.getElementById('toastNotif');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), duration);
  }

  const avatarSVG = `
    <svg viewBox="0 0 40 40" fill="none" width="40" height="40">
      <circle cx="20" cy="20" r="20" fill="#d0ccc8"/>
      <circle cx="20" cy="16" r="7" fill="#b0aba7"/>
      <ellipse cx="20" cy="34" rx="11" ry="8" fill="#b0aba7"/>
    </svg>`;

  function createCommentCard(item) {
    const isDeleted = item.is_deleted || false;
    const bodyText = item.message || item.comment || item.content || '';    
    const bodyClass = isDeleted ? 'comment-body deleted' : 'comment-body';
    const author    = item.name || item.username || 'Pengguna';
    const dateStr   = item.created_at || item.date || item.timestamp || new Date().toISOString();

    const card = document.createElement('div');
    card.className  = 'comment-card';
    card.dataset.id = item.id;

    card.innerHTML = `
      <div class="comment-header">
        <div class="comment-avatar">${avatarSVG}</div>
        <div class="comment-meta">
          <div class="comment-author">${escapeHtml(author)}</div>
          <div class="comment-time">${formatTime(dateStr)}</div>
        </div>
      </div>

      <div class="${bodyClass}" id="body-${item.id}">${escapeHtml(bodyText)}</div>

      ${!isDeleted ? `
      <div class="edit-form" id="edit-${item.id}">
        <textarea id="edit-text-${item.id}">${escapeHtml(bodyText)}</textarea>
        <div class="edit-actions">
          <button class="btn-save" onclick="saveEdit(${item.id})">Simpan</button>
          <button class="btn-cancel" onclick="cancelEdit(${item.id})">Batal</button>
        </div>
      </div>` : ''}

      ${!isDeleted ? `
      <div class="comment-menu-wrap">
        <button class="btn-dots" onclick="toggleDropdown(${item.id})" title="Opsi">⋯</button>
        <div class="dots-dropdown" id="dropdown-${item.id}">
          <button onclick="openEdit(${item.id})">Edit</button>
          <button class="btn-hapus" onclick="deleteComment(${item.id})">Hapus</button>
        </div>
      </div>` : ''}
    `;

    return card;
  }

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  async function loadComments() {
    const list = document.getElementById('commentList');
    list.innerHTML = `<div class="state-box"><div class="icon">⏳</div><p>Memuat komentar...</p></div>`;

    try {
      const res  = await fetch(COMMENTS_ENDPOINT);
      const json = await res.json();

      const items = Array.isArray(json) ? json : (json.data || []);

      if (items.length === 0) {
        list.innerHTML = `
          <div class="state-box">
            <div class="icon">💬</div>
            <p>Belum ada komentar.</p>
          </div>`;
        return;
      }

      list.innerHTML = '';
      items.forEach(item => list.appendChild(createCommentCard(item)));

    } catch (err) {
      list.innerHTML = `
        <div class="state-box">
          <div class="icon">⚠️</div>
          <p>Gagal memuat komentar.</p>
          <p style="font-size:12px;color:#aaa;margin-top:6px;">Pastikan server berjalan di <strong>${API_BASE}</strong></p>
        </div>`;
    }
  }

  function toggleDropdown(id) {
    document.querySelectorAll('.dots-dropdown.open').forEach(el => {
      if (el.id !== `dropdown-${id}`) el.classList.remove('open');
    });
    document.getElementById(`dropdown-${id}`).classList.toggle('open');
  }

  document.addEventListener('click', (e) => {
    if (!e.target.closest('.comment-menu-wrap')) {
      document.querySelectorAll('.dots-dropdown.open').forEach(el => el.classList.remove('open'));
    }
  });

  function openEdit(id) {
    document.getElementById(`dropdown-${id}`).classList.remove('open');
    document.getElementById(`body-${id}`).style.display  = 'none';
    document.getElementById(`edit-${id}`).classList.add('open');
    document.getElementById(`edit-text-${id}`).focus();
  }

  function cancelEdit(id) {
    document.getElementById(`edit-${id}`).classList.remove('open');
    document.getElementById(`body-${id}`).style.display = '';
  }

  async function saveEdit(id) {
    const newText = document.getElementById(`edit-text-${id}`).value.trim();
    if (!newText) { showToast('⚠️ Komentar tidak boleh kosong'); return; }

    try {
      const res = await fetch(`${COMMENTS_ENDPOINT}/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: newText })
      });

      if (!res.ok) throw new Error('Gagal menyimpan');

      document.getElementById(`body-${id}`).textContent = newText;
      cancelEdit(id);
      showToast('✅ Komentar berhasil diperbarui');
      alert("Komentar berhasil diperbarui!")
    } catch (err) {
      showToast('❌ Gagal menyimpan perubahan');
    }
  }

  async function deleteComment(id) {
    if (!confirm('Hapus komentar ini?')) return;

    try {
      const res = await fetch(`${COMMENTS_ENDPOINT}/${id}`, {
        method: 'DELETE'
      });

      if (!res.ok) throw new Error('Gagal menghapus');

      const card = document.querySelector(`.comment-card[data-id="${id}"]`);
      if (card) card.remove();

      showToast('🗑️ Komentar berhasil dihapus');
    } catch (err) {
      showToast('❌ Gagal menghapus komentar');
    }
  }

  function formatTime(dateString) {
    const date = new Date(dateString);

    return date.toLocaleString('id-ID', {
      day: '2-digit',
      month: 'short',
      year: 'numeric',
    });
  }

  loadComments();
</script>

</body>
</html>