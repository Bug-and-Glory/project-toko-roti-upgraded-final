<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Komentar — YumYum Bakery</title>

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>

  <style>
    /* ===== CSS VARIABLES ===== */
    :root {
      --navbar-bg:   #4E2609;
      --footer-bg:   #4E2609;
      --cart-btn:    #754C27;
      --cream:       #f5f0e8;
      --brown-dark:  #3b1f0e;
      --brown-mid:   #5c2d0e;
      --brown-light: #8b4513;
      --gold:        #c9922a;
      --gold-light:  #e8b84b;
      --white:       #fff;
      --text-dark:   #2b1a0a;
      --text-gray:   #666;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Poppins', sans-serif;
      background: var(--cream);
      color: var(--text-dark);
    }

    /* ===================================================
       NAVBAR
    =================================================== */
    .navbar {
      background: var(--navbar-bg) !important;
      padding: 10px 48px;
      box-shadow: 0 3px 16px rgba(0,0,0,0.3);
    }

    .nav-logo-img { height: 50px; width: auto; object-fit: contain; }

    .nav-logo-fallback { display: flex; align-items: center; gap: 10px; }
    .nav-logo-fallback .logo-box {
      width: 48px; height: 48px;
      background: var(--cart-btn);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
    }
    .nav-logo-fallback .brand-name {
      font-family: 'Playfair Display', serif;
      font-weight: 700;
    }
    .nav-logo-fallback .brand-sub {
      letter-spacing: 2px;
      text-transform: uppercase;
      font-size: 11px;
    }

    .navbar-nav .nav-link {
      font-family: 'Poppins', sans-serif;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #fff;
    }
    .navbar-nav .nav-link:hover { color: var(--gold-light) !important; }

    .btn-cart {
      background: var(--cart-btn); color: #fff; border: none;
      padding: 10px 22px; border-radius: 8px; font-family: 'Marmelad', sans-serif;
      font-size: 15px; cursor: pointer; display: flex; align-items: center; gap: 8px;
      box-shadow: 0 4px 18px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.18);
      transition: background 0.2s, transform 0.15s;
    }
    .btn-cart:hover { background: #8a5c30; transform: translateY(-1px); }
    .btn-cart img { width: 20px; height: 20px; filter: brightness(0) invert(1); }

    .cart-badge {
      position: absolute;
      top: -8px; right: -8px;
      background: #e74c3c;
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      width: 20px; height: 20px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      display: none;
    }

    /* Search Bar */
    .search-wrapper {
      position: relative;
      display: flex;
      align-items: center;
    }
    #searchInput {
      width: 0;
      opacity: 0;
      padding: 0;
      border: none;
      outline: none;
      background: rgba(255,255,255,0.15);
      color: #fff;
      font-family: 'Poppins', sans-serif;
      font-size: 13px;
      border-radius: 8px;
      transition: width 0.35s ease, opacity 0.35s ease, padding 0.35s ease;
    }
    #searchInput::placeholder { color: rgba(255,255,255,0.6); }
    #searchInput.open {
      width: 200px;
      opacity: 1;
      padding: 8px 14px;
      margin-right: 8px;
    }

    .btn-search {
      background: rgba(255,255,255,0.42); backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,0.35); width: 44px; height: 44px;
      border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center;
      box-shadow: 0 4px 14px rgba(0,0,0,0.25); transition: background 0.2s;
    }
    .btn-search:hover { background: rgba(255,255,255,0.6); }
    .btn-search img { width: 20px; height: 20px; }


    /* ===== FOOTER (copy dari index.html) ===== */
    footer {
      background: var(--footer-bg); color: rgba(255,255,255,0.9);
      padding: 60px 48px 30px; font-family: 'Poppins', sans-serif;
    }
    .footer-logo-main {
      width: 100%; max-width: 220px; border: 1.5px solid #dcb786;
      padding: 8px; margin-bottom: 30px; object-fit: contain;
    }
    .footer-halal { width: 85px; height: 85px; object-fit: contain; }
    footer h4 {
      font-family: 'Poppins', sans-serif; font-size: 13px; font-weight: 700;
      letter-spacing: 1px; text-transform: uppercase; color: #fff; margin-bottom: 14px;
    }
    footer ul { list-style: none; padding: 0; margin: 0; }
    footer ul li { margin-bottom: 8px; }
    footer ul li a { text-decoration: none; color: rgba(255,255,255,0.7); font-size: 13px; transition: color 0.2s; }
    footer ul li a:hover { color: var(--gold-light); }
    .contact-item { display: flex; align-items: center; gap: 10px; color: rgba(255,255,255,0.8); font-size: 13px; margin-bottom: 10px; }
    .contact-item img { width: 20px; height: 20px; object-fit: contain; filter: brightness(0) invert(1); opacity: 0.85; }
    .mt-sponsor { margin-top: 32px; }
    .sponsor-logo-box {
      background: #fff; border-radius: 8px; padding: 8px 10px;
      display: flex; align-items: center; justify-content: center; height: 40px; overflow: hidden;
    }
    .sponsor-logo-box img { max-width: 100%; max-height: 20px; object-fit: contain; }
    .mt-pengaduan { margin-top: 32px; }
    .complaint-section p { font-size: 12px; color: rgba(255,255,255,0.7); line-height: 1.8; margin-bottom: 0; }
    .footer-divider { border: none; border-top: 1px solid rgba(255,255,255,0.15); margin: 40px 0 16px; }
    .footer-bottom { text-align: center; font-size: 12px; color: rgba(255,255,255,0.4); }

    /* ===== PAGE CONTENT ===== */
    .page-wrapper {
      max-width: 860px;
      margin: 48px auto 64px;
      padding: 0 24px;
    }

    .page-title {
      font-family: 'Playfair Display', serif;
      font-size: 22px; font-weight: 700;
      color: var(--text-dark);
      margin-bottom: 28px;
      padding-bottom: 14px;
      border-bottom: 2px solid #e8e2da;
    }

    /* ===== COMMENT CARD ===== */
    .comment-card {
      background: #fff;
      border: 1px solid #e5e5e5;
      border-radius: 10px;
      padding: 22px 24px 18px;
      margin-bottom: 16px;
      position: relative;
    }

    /* Header: avatar + nama + waktu */
    .comment-header {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      margin-bottom: 14px;
    }
    .comment-avatar {
      width: 40px; height: 40px; border-radius: 50%;
      background: #d0ccc8; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      color: #888; font-size: 20px;
    }
    .comment-avatar svg { display: block; }
    .comment-meta { flex: 1; }
    .comment-author {
      font-size: 15px; font-weight: 700;
      color: var(--text-dark); margin-bottom: 2px;
    }
    .comment-date {
      font-size: 12px;
      color: var(--text-gray);
    }

    /* Konten komentar */
    .comment-body {
      font-size: 14px;
      line-height: 1.7;
      color: #333;
      margin-bottom: 16px;
      /* Pesan yang dihapus tampil italic & abu */
    }
    .comment-body.deleted {
      color: #999;
      font-style: italic;
    }

    /* ===== TOMBOL TITIK TIGA + MENU EDIT/HAPUS ===== */
    .comment-menu-wrap {
      position: absolute;
      top: 18px; right: 18px;
    }
    .btn-dots {
      width: 34px; height: 34px; border-radius: 8px;
      border: 1.5px solid #d0d0d0; background: #fff;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: background 0.15s;
      color: #444; font-size: 18px; letter-spacing: 1px;
      font-weight: 700; padding: 0;
    }
    .btn-dots:hover { background: #f4f4f4; }

    .dots-dropdown {
      display: none;
      position: absolute;
      top: 40px; right: 0;
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 8px;
      box-shadow: 0 6px 20px rgba(0,0,0,0.12);
      min-width: 120px;
      z-index: 100;
      overflow: hidden;
    }
    .dots-dropdown.open { display: block; }

    .dots-dropdown button {
      display: block; width: 100%; text-align: left;
      padding: 11px 18px; border: none; background: none;
      font-family: 'Poppins', sans-serif; font-size: 14px;
      color: var(--text-dark); cursor: pointer; transition: background 0.15s;
    }
    .dots-dropdown button:hover { background: #f7f7f7; }
    .dots-dropdown button.btn-hapus { color: #e74c3c; }
    .dots-dropdown button.btn-hapus:hover { background: #fff5f5; }

    /* ===== VOTE (upvote / downvote) ===== */
    .comment-footer {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .vote-btn {
      display: inline-flex; align-items: center; gap: 5px;
      border: none; background: none; cursor: pointer;
      font-family: 'Poppins', sans-serif; font-size: 13px;
      color: var(--text-gray); padding: 0; transition: color 0.15s;
    }
    .vote-btn:hover { color: var(--text-dark); }
    .vote-btn svg { width: 15px; height: 15px; stroke: currentColor; fill: none; }
    .vote-separator { color: #d0d0d0; font-size: 14px; }

    /* ===== EDIT INLINE FORM ===== */
    .edit-form {
      display: none;
      margin-top: 10px;
    }
    .edit-form.open { display: block; }
    .edit-form textarea {
      width: 100%; padding: 10px 14px; border: 1.5px solid #d0d0d0;
      border-radius: 8px; font-family: 'Poppins', sans-serif; font-size: 14px;
      resize: vertical; outline: none; transition: border-color 0.2s;
      min-height: 80px;
    }
    .edit-form textarea:focus { border-color: var(--brown-light); }
    .edit-actions { display: flex; gap: 10px; margin-top: 10px; }
    .btn-save {
      background: var(--brown-dark); color: #fff; border: none;
      border-radius: 8px; padding: 8px 22px;
      font-family: 'Poppins', sans-serif; font-size: 13px; font-weight: 600;
      cursor: pointer; transition: background 0.2s;
    }
    .btn-save:hover { background: var(--brown-mid); }
    .btn-cancel {
      background: #f0f0f0; color: #555; border: none;
      border-radius: 8px; padding: 8px 22px;
      font-family: 'Poppins', sans-serif; font-size: 13px;
      cursor: pointer; transition: background 0.2s;
    }
    .btn-cancel:hover { background: #e4e4e4; }

    /* ===== LOADING & ERROR ===== */
    .state-box {
      text-align: center; padding: 60px 20px; color: var(--text-gray);
    }
    .state-box .icon { font-size: 40px; margin-bottom: 12px; }

    /* ===== TOAST ===== */
    .toast-notification {
      position: fixed; bottom: 30px; left: 50%;
      transform: translateX(-50%) translateY(20px);
      background: var(--brown-dark); color: #fff;
      padding: 12px 24px; border-radius: 30px; font-size: 13px; font-weight: 500;
      z-index: 2000; opacity: 0; transition: opacity 0.3s, transform 0.3s; white-space: nowrap;
    }
    .toast-notification.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    .comment-time {
      font-size: 12px;
      color: #888;
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 992px) {
      .navbar { padding: 10px 20px; }
      footer { padding: 40px 20px 20px; }
      .page-wrapper { margin: 32px auto 48px; padding: 0 16px; }
    }
  </style>
</head>
