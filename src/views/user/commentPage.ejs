<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>
    <%= title || "Comments - YumYum Bakery" %>
  </title>

  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap"
    rel="stylesheet" />

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

  <link href="/css/index.css" rel="stylesheet" />
  <link href="/css/commentPage.css" rel="stylesheet" />
</head>

<body data-user-id="<%= typeof user !== 'undefined' && user ? user.id : '' %>">

  <%- include("./navbar") %>

    <main class="comment-page-wrapper">

      <div class="comment-page-heading">
        <p class="celebrate">Customer Voices</p>
        <h1>Komentar & Saran</h1>
        <p class="sub-title">- PENDAPAT PELANGGAN YUMYUM BAKERY -</p>
      </div>

      <div class="comment-top-actions">
        <a href="/comment" class="btn-add-comment">
          TULIS KOMENTAR
        </a>
      </div>

      <% if (typeof message !=="undefined" && message) { %>
        <div class="alert alert-info comment-alert">
          <%= message %>
        </div>
        <% } %>

          <div class="comment-list">

            <% if (!comments || comments.length===0) { %>

              <div class="empty-comment-box">
                <div class="empty-icon">💬</div>
                <p>Belum ada komentar.</p>
              </div>

              <% } else { %>

                <% comments.forEach((comment)=> { %>
                  <% const commentId=comment.id || comment.comment_id; const
                    commenterUsername=comment.Comment_User?.username || comment.username || "User" ; %>

                    <div class="comment-card">

                      <div class="comment-header">
                        <div class="comment-avatar">
                          <%= commenterUsername.charAt(0).toUpperCase() %>
                        </div>

                        <div class="comment-meta">
                          <h3>
                            <%= commenterUsername %>
                          </h3>

                          <p>
                            <%= new Date(comment.created_at).toLocaleDateString("id-ID", { day: "2-digit" ,
                              month: "short" , year: "numeric" }) %>
                          </p>
                        </div>
                      </div>

                      <p class="comment-body" id="comment-text-<%= commentId %>">
                        <%= comment.comment %>
                      </p>

                      <% if (typeof user !=="undefined" && user && Number(comment.user_id)===Number(user.id)) { %>

                        <div class="comment-menu-wrap">
                          <button type="button" class="btn-dots" onclick="toggleDropdown('<%= commentId %>')">
                            ⋯
                          </button>

                          <div class="dots-dropdown" id="dropdown-<%= commentId %>">
                            <button type="button" onclick="showEditForm('<%= commentId %>')">
                              Edit
                            </button>

                            <form action="/comment/<%= commentId %>/delete" method="POST"
                              onsubmit="return confirm('Yakin ingin menghapus komentar ini?')">
                              <button type="submit" class="btn-delete">
                                Hapus
                              </button>
                            </form>
                          </div>
                        </div>

                        <form action="/comment/<%= commentId %>/edit" method="POST" class="edit-comment-form"
                          id="edit-form-<%= commentId %>">
                          <textarea name="comment" rows="4" required><%= comment.comment %></textarea>

                          <div class="edit-actions">
                            <button type="submit" class="btn-save-edit">
                              Simpan
                            </button>

                            <button type="button" class="btn-cancel-edit" onclick="hideEditForm('<%= commentId %>')">
                              Batal
                            </button>
                          </div>
                        </form>

                        <% } %>

                    </div>

                    <% }) %>

                      <% } %>

          </div>

    </main>

    <%- include("./footer") %>

      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

      <script>
        function toggleDropdown(id) {
          document.querySelectorAll(".dots-dropdown.show").forEach((dropdown) => {
            if (dropdown.id !== `dropdown-${id}`) {
              dropdown.classList.remove("show");
            }
          });

          document.getElementById(`dropdown-${id}`).classList.toggle("show");
        }

        function showEditForm(id) {
          document.getElementById(`dropdown-${id}`).classList.remove("show");
          document.getElementById(`edit-form-${id}`).classList.add("show");
          document.getElementById(`comment-text-${id}`).style.display = "none";
        }

        function hideEditForm(id) {
          document.getElementById(`edit-form-${id}`).classList.remove("show");
          document.getElementById(`comment-text-${id}`).style.display = "block";
        }

        document.addEventListener("click", function (event) {
          if (!event.target.closest(".comment-menu-wrap")) {
            document.querySelectorAll(".dots-dropdown.show").forEach((dropdown) => {
              dropdown.classList.remove("show");
            });
          }
        });
      </script>

      <script src="/socket.io/socket.io.js"></script>
      <script>
        const socket = io();
        const currentUserId = document.body.dataset.userId || null;

        function escapeHTML(str) {
          const div = document.createElement("div");
          div.textContent = str;
          return div.innerHTML;
        }

        socket.on("newComment", (data) => {
          const commentList = document.querySelector(".comment-list");

          const emptyBox = commentList.querySelector(".empty-comment-box");
          if (emptyBox) emptyBox.remove();

          const tanggal = new Date(data.created_at).toLocaleDateString("id-ID", {
            day: "2-digit",
            month: "short",
            year: "numeric",
          });

          const isOwner = currentUserId && Number(data.user_id) === Number(currentUserId);

          const card = document.createElement("div");
          card.classList.add("comment-card");
          card.innerHTML = `
            <div class="comment-header">
              <div class="comment-avatar">${escapeHTML(data.name.charAt(0).toUpperCase())}</div>
              <div class="comment-meta">
                <h3>${escapeHTML(data.name)}</h3>
                <p>${tanggal}</p>
              </div>
            </div>
            <p class="comment-body" id="comment-text-${data.id}">${escapeHTML(data.comment)}</p>
            ${isOwner ? `
              <div class="comment-menu-wrap">
                <button type="button" class="btn-dots" onclick="toggleDropdown('${data.id}')">⋯</button>
                <div class="dots-dropdown" id="dropdown-${data.id}">
                  <button type="button" onclick="showEditForm('${data.id}')">Edit</button>
                  <form action="/comment/${data.id}/delete" method="POST"
                    onsubmit="return confirm('Yakin ingin menghapus komentar ini?')">
                    <button type="submit" class="btn-delete">Hapus</button>
                  </form>
                </div>
              </div>
              <form action="/comment/${data.id}/edit" method="POST" class="edit-comment-form" id="edit-form-${data.id}">
                <textarea name="comment" rows="4" required>${escapeHTML(data.comment)}</textarea>
                <div class="edit-actions">
                  <button type="submit" class="btn-save-edit">Simpan</button>
                  <button type="button" class="btn-cancel-edit" onclick="hideEditForm('${data.id}')">Batal</button>
                </div>
              </form>
            ` : ""}
          `;

          commentList.prepend(card);
        });

        // Update isi komentar secara real-time di semua tab/browser lain
        socket.on("updateComment", (data) => {
          const commentText = document.getElementById(`comment-text-${data.id}`);
          if (commentText) {
            commentText.textContent = data.comment;
          }

          // Kalau kebetulan form edit punya user itu sedang kebuka, ikut disamakan isinya
          const editForm = document.getElementById(`edit-form-${data.id}`);
          if (editForm) {
            const textarea = editForm.querySelector("textarea[name='comment']");
            if (textarea) textarea.value = data.comment;
          }
        });

        // Hapus kartu komentar secara real-time di semua tab/browser lain
        socket.on("deleteComment", (data) => {
          const commentText = document.getElementById(`comment-text-${data.id}`);
          const card = commentText ? commentText.closest(".comment-card") : null;
          if (card) {
            card.remove();
          }

          // Kalau komentar habis semua, tampilkan lagi kotak "Belum ada komentar"
          const commentList = document.querySelector(".comment-list");
          if (commentList && commentList.children.length === 0) {
            commentList.innerHTML = `
              <div class="empty-comment-box">
                <div class="empty-icon">💬</div>
                <p>Belum ada komentar.</p>
              </div>
            `;
          }
        });
      </script>

      <script>
        // Auto-hide pesan notifikasi & bersihkan URL biar gak nongol lagi pas refresh
        const alertBox = document.querySelector(".comment-alert");
        if (alertBox) {
          setTimeout(() => {
            alertBox.style.transition = "opacity 0.5s ease";
            alertBox.style.opacity = "0";
            setTimeout(() => alertBox.remove(), 500);
          }, 2500);

          const cleanUrl = window.location.pathname;
          window.history.replaceState(null, "", cleanUrl);
        }
      </script>

</body>

</html>