<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>History – YumYum Bakery</title>

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/history.css">
</head>
<body>

<!-- ============================================================
     NAVBAR
============================================================ -->
<nav class="navbar navbar-expand-lg sticky-top">
  <div class="container-fluid px-0">
    <a class="navbar-brand ms-0" href="/">
      <img src="/logo/logo_nama.png" alt="YumYum Bakery" class="nav-logo-img"
           onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
      <div class="nav-logo-fallback" style="display:none;">
        <div class="logo-box">
          <svg viewBox="0 0 48 48" fill="none" width="32" height="32">
            <ellipse cx="24" cy="28" rx="16" ry="10" fill="#c9922a"/>
            <ellipse cx="24" cy="26" rx="14" ry="8" fill="#e8b84b"/>
            <path d="M16 18 Q24 10 32 18" stroke="#c9922a" stroke-width="2.5" fill="none" stroke-linecap="round"/>
            <text x="15" y="33" font-size="9" font-weight="bold" fill="#3b1f0e" font-family="serif">YB</text>
          </svg>
        </div>
        <div>
          <span class="brand-name" style="color:#fff">YumYum</span>
          <span class="brand-sub d-block" style="color:rgba(255,255,255,0.7)">Bakery</span>
        </div>
      </div>
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarMain">
      <ul class="navbar-nav mx-auto">
        <li class="nav-item"><a class="nav-link" href="/menu">MENU</a></li>
        <li class="nav-item"><a class="nav-link" href="/store">STORE</a></li>
        <li class="nav-item"><a class="nav-link" href="/about_us">ABOUT US</a></li>
        <li class="nav-item"><a class="nav-link active-link" href="/history">HISTORY</a></li>
      </ul>
      <div class="d-flex align-items-center gap-3 mt-2 mt-lg-0">
        <a href="/cart" class="btn-cart">
          <img src="/icon/keranjang.png" alt="Cart"
               onerror="this.style.display='none'"/> CART
        </a>
      </div>
    </div>
  </div>
</nav>

<!-- ============================================================
     PAGE HEADER
============================================================ -->
<div class="page-header">
  <h1>Order History</h1>
  <p>Semua riwayat transaksi pelanggan YumYum Bakery</p>
</div>

<!-- ============================================================
     HISTORY CONTENT
============================================================ -->
<div class="history-section">
  <div class="filter-bar">
    <input type="text" id="customerSearch" placeholder="Cari nama customer..." oninput="filterOrders()"/>
  </div>

  <div id="orderList">

    <% if (!orders || !orders.length) { %>

      <div class="state-msg">
        <div class="icon">📭</div>
        <p>Belum ada riwayat pesanan ditemukan.</p>
      </div>

    <% } else { %>

      <% orders.forEach((order, i) => { %>

      <div class="order-card" data-customer="<%= order.customer_name.toLowerCase() %>" style="animation-delay: <%= i * 0.06 %>s">

        <div class="card-head">
          <div>
            <div class="order-title">Order #<%= order.order_id %></div>
            <div class="order-customer"><%= order.customer_name %></div>
          </div>
          <span class="badge-date">
            <%= new Date(order.order_date).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
          </span>
        </div>

        <div class="card-body-inner">
          <div class="items-label">Detail Pesanan</div>

          <% if (order.Order_OrderDetail && order.Order_OrderDetail.length) { %>

            <% order.Order_OrderDetail.forEach(item => { %>
            <div class="item-row">
              <img class="item-img"
                   src="<%= item.OrderDetail_Product.img_url || '' %>"
                   alt="<%= item.OrderDetail_Product.product_name %>"
                   onerror="this.src='https://images.unsplash.com/photo-1555507036-ab1f4038808a?w=100&h=100&fit=crop'"/>
              <span class="item-name"><%= item.OrderDetail_Product.product_name %></span>
              <span class="item-qty">x<%= item.quantity %></span>
              <span class="item-subtotal">Rp <%= new Intl.NumberFormat('id-ID').format(item.subtotal) %></span>
            </div>
            <% }) %>

          <% } else { %>
            <p style="color:#aaa;font-size:13px;">Tidak ada item.</p>
          <% } %>

        </div>

        <div class="card-foot">
          <span class="total-label">Total Pembayaran</span>
          <span class="total-amount">Rp <%= new Intl.NumberFormat('id-ID').format(order.total_amount) %></span>
        </div>

      </div>

      <% }) %>

    <% } %>

  </div>
</div>

<!-- ============================================================
     FOOTER
============================================================ -->
<footer>
  <div class="row g-4 mb-4">
    <div class="col-lg-3 col-md-4 col-sm-6">
      <div class="d-flex flex-column align-items-start">
        <img src="/logo/logo_aja.png" alt="YumYum Bakery Logo" class="footer-logo-main"
             onerror="this.src='https://via.placeholder.com/200x100?text=YumYum+Logo'"/>
        <img src="/icon/icon halal.png" alt="Halal" class="footer-halal"
             onerror="this.src='https://via.placeholder.com/80?text=Halal'"/>
      </div>
    </div>
    <div class="col-lg-3 col-md-4 col-sm-6">
      <h4>YUMYUM BAKERY</h4>
      <ul>
        <li><a href="/about_us">About Us</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <div class="mt-sponsor">
        <h4>SPONSOR</h4>
        <div class="row g-2">
          <div class="col-6"><div class="sponsor-logo-box"><img src="/logo/anchor.png" alt="Anchor" onerror="this.src='https://via.placeholder.com/100x40?text=Anchor'"></div></div>
          <div class="col-6"><div class="sponsor-logo-box"><img src="/logo/indofood.png" alt="Indofood" onerror="this.src='https://via.placeholder.com/100x40?text=Indofood'"></div></div>
          <div class="col-6"><div class="sponsor-logo-box"><img src="/logo/gofood.png" alt="GoFood" onerror="this.src='https://via.placeholder.com/100x40?text=GoFood'"></div></div>
          <div class="col-6"><div class="sponsor-logo-box"><img src="/logo/tokped.png" alt="Tokopedia" onerror="this.src='https://via.placeholder.com/100x40?text=Tokopedia'"></div></div>
        </div>
      </div>
    </div>
    <div class="col-lg-2 col-md-4 col-sm-12 mt-4 mt-md-0">
      <h4>HELP CENTER</h4>
      <ul><li><a href="#">Privacy Policy</a></li></ul>
    </div>
    <div class="col-lg-4 col-md-12 mt-4 mt-lg-0">
      <h4>CONTACT US</h4>
      <div class="contact-item">
        <img src="/icon/tlp.png" alt="phone" onerror="this.outerHTML='<span style=\'font-size:20px;\'>📞</span>'"/> 889070999
      </div>
      <div class="contact-item">
        <img src="icon/wa.png" alt="whatsapp" onerror="this.outerHTML='<span style=\'font-size:20px;\'>📱</span>'"/> +62 887 1447 0009
      </div>
      <div class="contact-item">
        <img src="/icon/ig.png" alt="instagram" onerror="this.outerHTML='<span style=\'font-size:20px;\'>📸</span>'"/> @YumYum_Bakery
      </div>
      <div class="mt-pengaduan">
        <h4>LAYANAN PENGADUAN</h4>
        <div class="complaint-section">
          <p>PT Matahari Bulan Bintang Angkasa</p>
          <p>Email : marketing@yumyum.com</p>
          <p>0867 0000 1222 (WhatsApp)</p>
        </div>
      </div>
    </div>
  </div>
  <hr class="footer-divider"/>
  <p class="footer-bottom">© 2024 YumYum Bakery. All rights reserved.</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function filterOrders() {
    const q = document.getElementById('customerSearch').value.toLowerCase();
    document.querySelectorAll('.order-card').forEach(card => {
      const match = card.dataset.customer.includes(q);
      card.style.display = match ? '' : 'none';
    });
  }
</script>
</body>
</html>