<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>History – YumYum Bakery</title>

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/history.css">
  <link rel="stylesheet" href="/css/index.css">
</head>
<body>

<!-- ============================================================
     NAVBAR
============================================================ -->
<%- include('navbar') %>

<!-- ============================================================
     PAGE HEADER
============================================================ -->
<div class="page-header">
  <h1>Order History</h1>
  <p>Semua riwayat transaksi pelanggan YumYum Bakery</p>
</div>

<!-- ============================================================
     HISTORY CONTENT
============================================================ -->
<div class="history-section">

  <% if (!orders || orders.length === 0) { %>

    <div class="state-msg">
      <div class="icon">📭</div>
      <p>Belum ada riwayat pesanan.</p>
    </div>

  <% } else { %>

    <% orders.forEach((order) => { %>

      <div class="order-card">

        <div class="card-head">
          <div>
            <div class="order-title">
              Order #<%= order.order_id %>
            </div>

            <div class="order-customer">
              <%= order.customer_name %>
            </div>
          </div>

          <span class="badge-date">
            <%= new Date(order.order_date).toLocaleDateString("id-ID") %>
          </span>
        </div>

        <div class="card-body-inner">
          <div class="items-label">Detail Pesanan</div>

          <% order.Order_OrderDetail.forEach((detail) => { %>

            <div class="item-row">
              <img
                class="item-img"
                src="<%= detail.OrderDetail_Product.img_url %>"
                alt="<%= detail.OrderDetail_Product.name %>">

              <span class="item-name">
                <%= detail.OrderDetail_Product.name %>
              </span>

              <span class="item-qty">
                x<%= detail.quantity %>
              </span>

              <span class="item-subtotal">
                Rp <%= Number(detail.subtotal).toLocaleString("id-ID") %>
              </span>
            </div>

          <% }) %>

        </div>

        <div class="card-foot">
          <span class="total-label">Total Pembayaran</span>

          <span class="total-amount">
            Rp <%= Number(order.total_amount).toLocaleString("id-ID") %>
          </span>
        </div>

      </div>

    <% }) %>

  <% } %>

</div>

<!-- ============================================================
     FOOTER
============================================================ -->
<%- include('footer') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function filterOrders() {
    const q = document.getElementById('customerSearch').value.toLowerCase();
    document.querySelectorAll('.order-card').forEach(card => {
      const match = card.dataset.customer.includes(q);
      card.style.display = match ? '' : 'none';
    });
  }
</script>
</body>
</html>