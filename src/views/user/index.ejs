<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>YumYum Bakery</title>

  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap"
    rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/index.css">
</head>

<body>

  <nav class="navbar navbar-expand-lg sticky-top">
    <div class="container-fluid px-0">
      <a class="navbar-brand ms-0" href="/">
        <img src="/logo/logo_nama.png" alt="YumYum Bakery" class="nav-logo-img"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
        <div class="nav-logo-fallback" style="display:none;">
          <div class="logo-box">
            <svg viewBox="0 0 48 48" fill="none" width="32" height="32">
              <ellipse cx="24" cy="28" rx="16" ry="10" fill="#c9922a" />
              <ellipse cx="24" cy="26" rx="14" ry="8" fill="#e8b84b" />
              <path d="M16 18 Q24 10 32 18" stroke="#c9922a" stroke-width="2.5" fill="none" stroke-linecap="round" />
              <text x="15" y="33" font-size="9" font-weight="bold" fill="#3b1f0e" font-family="serif">YB</text>
            </svg>
          </div>
          <div>
            <span class="brand-name" style="color:#fff">YumYum</span>
            <span class="brand-sub d-block" style="color:rgba(255,255,255,0.7)">Bakery</span>
          </div>
        </div>
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarMain">
        <ul class="navbar-nav mx-auto">
          <li class="nav-item"><a class="nav-link" href="/menu">MENU</a></li>
          <li class="nav-item"><a class="nav-link" href="/store">STORE</a></li>
          <li class="nav-item"><a class="nav-link" href="/about_us">ABOUT US</a></li>
          <li class="nav-item"><a class="nav-link" href="/history">HISTORY</a></li>
        </ul>

        <div class="d-flex align-items-center gap-3 mt-2 mt-lg-0">

          <a href="/cart" class="btn-cart-navbar">
            <span>CART</span>
            <img src="/icon/keranjang.png" alt="Cart">
          </a>

          <% if (typeof user !=="undefined" && user) { %>

            <details class="user-navbar-menu">
              <summary class="btn-user-navbar">
                <%= user.username %>
              </summary>

              <div class="user-navbar-dropdown">
                <a href="/logout">
                  LOGOUT
                </a>
              </div>
            </details>

            <% } else { %>

              <a href="/login" class="btn-login-navbar">
                LOGIN/SIGN UP
              </a>

              <% } %>

        </div>

      </div>
    </div>
  </nav>

  <div class="hero-wrapper">
    <div class="hero">
      <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="4000">
        <div class="carousel-indicators">
          <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
          <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
          <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
        </div>
        <div class="carousel-inner">
          <div class="carousel-item active">
            <div class="hero-slide">
              <img class="hero-slide-img" src="/gambar/banner_1.png" alt="Promo YumYum 1"
                onerror="this.src='https://images.unsplash.com/photo-1555507036-ab1f4038808a?w=1200'">
            </div>
          </div>
          <div class="carousel-item">
            <div class="hero-slide">
              <img class="hero-slide-img" src="/gambar/banner_2.png" alt="Promo YumYum 2"
                onerror="this.src='https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=1200'">
            </div>
          </div>
          <div class="carousel-item">
            <div class="hero-slide">
              <img class="hero-slide-img" src="/gambar/banner_3.png" alt="Promo YumYum 3"
                onerror="this.src='https://images.unsplash.com/photo-1515823064-d6e0c04616a7?w=1200'">
            </div>
          </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
          <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
          <span class="visually-hidden">Next</span>
        </button>
      </div>
    </div>
  </div>

  <div id="menu-section">
