<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>YumYum Bakery</title>

  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap"
    rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/index.css">
</head>

<body>

  <%- include('navbar') %>

  <div class="hero-wrapper">
    <div class="hero">
      <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="4000">
        <div class="carousel-indicators">
          <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
          <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
          <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
        </div>
        <div class="carousel-inner">
          <div class="carousel-item active">
            <div class="hero-slide">
              <img class="hero-slide-img" src="/gambar/banner_1.png" alt="Promo YumYum 1"
                onerror="this.src='https://images.unsplash.com/photo-1555507036-ab1f4038808a?w=1200'">
            </div>
          </div>
          <div class="carousel-item">
            <div class="hero-slide">
              <img class="hero-slide-img" src="/gambar/banner_2.png" alt="Promo YumYum 2"
                onerror="this.src='https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=1200'">
            </div>
          </div>
          <div class="carousel-item">
            <div class="hero-slide">
              <img class="hero-slide-img" src="/gambar/banner_3.png" alt="Promo YumYum 3"
                onerror="this.src='https://images.unsplash.com/photo-1515823064-d6e0c04616a7?w=1200'">
            </div>
          </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
          <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
          <span class="visually-hidden">Next</span>
        </button>
      </div>
    </div>
  </div>

  <div id="menu-section">
    <div class="section-heading">
      <p class="celebrate">Celebrate Every Moment</p>
      <h2>BUAT MOMEN SPESIAL MU LEBIH MANIS</h2>
      <p class="sub-title">- YUMMY BAKERY -</p>
    </div>

    <div class="products-grid-section">
      <div class="row g-4" id="productsGrid">

        <% if (!products || !products.length) { %>

          <div class="col-12 text-center py-5">
            <p>Belum ada produk pilihan tersedia.</p>
          </div>

        <% } else { %>

          <% products.forEach(p => { %>

          <div class="col-lg-4 col-md-6">
            <div class="product-card">
              <img src="<%= p.img_url || '' %>" alt="<%= p.name %>"
                   onerror="this.src='https://images.unsplash.com/photo-1555507036-ab1f4038808a?w=400&h=400&fit=crop'" />
              <div class="product-card-info">
                <p class="sub-cat-label">
                  <%= p.Product_SubCategory ? p.Product_SubCategory.name : '' %> ·
                  <%= p.Product_SubCategory && p.Product_SubCategory.Sub_MasterCategory ? p.Product_SubCategory.Sub_MasterCategory.name : '' %>
                </p>
                <h3><%= p.name %></h3>
                <p class="price">Rp <%= new Intl.NumberFormat('id-ID').format(p.price) %></p>
                <a href="/menu/<%= p.id %>" class="btn-add-card">+ Tambah ke Keranjang</a>
              </div>
            </div>
          </div>

          <% }) %>

        <% } %>

      </div>
    </div>

    <div class="see-more-wrap" id="seeMoreWrap" style="display: <%= products && products.length ? 'block' : 'none' %>;">
      <a href="/menu" class="btn-see-more">SEE MORE</a>
    </div>

    <div class="reviews-section">
      <div class="reviews-heading">
        <h2>REVIEW</h2>
      </div>
      <div class="row g-4 justify-content-center">
        <div class="col-lg-3 col-md-6 col-sm-6">
          <div class="review-wrapper">
            <div class="reviewer-profile"><img src="/gambar/muhadist.jpeg"
                onerror="this.src='https://ui-avatars.com/api/?name=Muhadist&background=a99d96&color=fff&size=140'" />
              <div class="stars">★★★★★</div><span class="reviewer-name">Muhadist</span>
            </div>
            <div class="review-box">
              <p>Tempatnya nyaman banget, Pastrynya enak-enak pokoknya RECOMMENDED!</p>
            </div>
          </div>
        </div>
        <div class="col-lg-3 col-md-6 col-sm-6">
          <div class="review-wrapper">
            <div class="reviewer-profile"><img src="/gambar/caroline.jpeg"
                onerror="this.src='https://ui-avatars.com/api/?name=Caroline&background=a99d96&color=fff&size=140'" />
              <div class="stars">★★★★☆</div><span class="reviewer-name">Caroline</span>
            </div>
            <div class="review-box">
              <p>Salah satu bakery favorit aku! Varian rotinya banyak dan semuanya enak. Recommended banget!</p>
            </div>
          </div>
        </div>
        <div class="col-lg-3 col-md-6 col-sm-6">
          <div class="review-wrapper">
            <div class="reviewer-profile"><img src="/gambar/rara.jpeg"
                onerror="this.src='https://ui-avatars.com/api/?name=Zahara&background=a99d96&color=fff&size=140'" />
              <div class="stars">★★★★★</div><span class="reviewer-name">Zahara</span>
            </div>
            <div class="review-box">
              <p>Gila sih ini enak banget 😭 croissant-nya flaky parah, wajib coba!</p>
            </div>
          </div>
        </div>
        <div class="col-lg-3 col-md-6 col-sm-6">
          <div class="review-wrapper">
            <div class="reviewer-profile"><img src="/gambar/fhilip.jpeg"
                onerror="this.src='https://ui-avatars.com/api/?name=Fhilip&background=a99d96&color=fff&size=140'" />
              <div class="stars">★★★★☆</div><span class="reviewer-name">Fhilip</span>
            </div>
            <div class="review-box">
              <p>Pastry-nya enak, nggak terlalu manis dan teksturnya pas. Cocok buat teman ngopi ☕</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%- include('footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      async function addToCart(productId, event) {
        if (event) {
          event.preventDefault();
          event.stopPropagation();
        }

        try {
          const response = await fetch('/cart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ product_id: productId, quantity: 1 })
          });

          if (response.ok) {
            alert("Produk berhasil ditambahkan ke keranjang!");
          } else {
            alert("Gagal menambahkan produk ke keranjang.");
          }
        } catch (error) {
          console.error("Gagal memproses keranjang:", error);
        }
      }

      document.addEventListener('DOMContentLoaded', () => {
        const searchInput = document.getElementById('searchInput');
        if (searchInput) {
          searchInput.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
              e.preventDefault();
              const keyword = this.value.trim();
              if (keyword) {
                window.location.href = `/menu?search=${encodeURIComponent(keyword)}`;
              }
            }
          });
        }
      });
    </script>

</body>

</html>