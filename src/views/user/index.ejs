      <p class="celebrate">Celebrate Every Moment</p>
      <h2>BUAT MOMEN SPESIAL MU LEBIH MANIS</h2>
      <p class="sub-title">- YUMMY BAKERY -</p>
    </div>

    <div class="products-grid-section">
      <div class="row g-4" id="productsGrid">
      </div>
    </div>

    <div class="see-more-wrap" id="seeMoreWrap" style="display:none;">
      <a href="/menu" class="btn-see-more">SEE MORE</a>
    </div>

    <div class="reviews-section">
      <div class="reviews-heading">
        <h2>REVIEW</h2>
      </div>
      <div class="row g-4 justify-content-center">
        <div class="col-lg-3 col-md-6 col-sm-6">
          <div class="review-wrapper">
            <div class="reviewer-profile"><img src="/gambar/muhadist.jpeg"
                onerror="this.src='https://ui-avatars.com/api/?name=Muhadist&background=a99d96&color=fff&size=140'" />
              <div class="stars">★★★★★</div><span class="reviewer-name">Muhadist</span>
            </div>
            <div class="review-box">
              <p>Tempatnya nyaman banget, Pastrynya enak-enak pokoknya RECOMMENDED!</p>
            </div>
          </div>
        </div>
        <div class="col-lg-3 col-md-6 col-sm-6">
          <div class="review-wrapper">
            <div class="reviewer-profile"><img src="/gambar/caroline.jpeg"
                onerror="this.src='https://ui-avatars.com/api/?name=Caroline&background=a99d96&color=fff&size=140'" />
              <div class="stars">★★★★☆</div><span class="reviewer-name">Caroline</span>
            </div>
            <div class="review-box">
              <p>Salah satu bakery favorit aku! Varian rotinya banyak dan semuanya enak. Recommended banget!</p>
            </div>
          </div>
        </div>
        <div class="col-lg-3 col-md-6 col-sm-6">
          <div class="review-wrapper">
            <div class="reviewer-profile"><img src="/gambar/rara.jpeg"
                onerror="this.src='https://ui-avatars.com/api/?name=Zahara&background=a99d96&color=fff&size=140'" />
              <div class="stars">★★★★★</div><span class="reviewer-name">Zahara</span>
            </div>
            <div class="review-box">
              <p>Gila sih ini enak banget 😭 croissant-nya flaky parah, wajib coba!</p>
            </div>
          </div>
        </div>
        <div class="col-lg-3 col-md-6 col-sm-6">
          <div class="review-wrapper">
            <div class="reviewer-profile"><img src="/gambar/fhilip.jpeg"
                onerror="this.src='https://ui-avatars.com/api/?name=Fhilip&background=a99d96&color=fff&size=140'" />
              <div class="stars">★★★★☆</div><span class="reviewer-name">Fhilip</span>
            </div>
            <div class="review-box">
              <p>Pastry-nya enak, nggak terlalu manis dan teksturnya pas. Cocok buat teman ngopi ☕</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <footer>
      <div class="row g-4 mb-4">
        <div class="col-lg-3 col-md-4 col-sm-6">
          <div class="d-flex flex-column align-items-start">
            <img src="/logo/logo_aja.png" alt="YumYum Bakery Logo" class="footer-logo-main"
              onerror="this.src='https://via.placeholder.com/200x100?text=YumYum+Logo'" />
            <img src="/icon/icon halal.png" alt="Halal" class="footer-halal"
              onerror="this.src='https://via.placeholder.com/80?text=Halal'" />
          </div>
        </div>

        <div class="col-lg-3 col-md-4 col-sm-6">
          <h4>YUMYUM BAKERY</h4>
          <ul>
            <li><a href="/about_us">About Us</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
          <div class="mt-sponsor">
            <h4>SPONSOR</h4>
            <div class="row g-2">
              <div class="col-6">
                <div class="sponsor-logo-box"><img src="/logo/anchor.png" alt="Anchor"
                    onerror="this.src='https://via.placeholder.com/100x40?text=Anchor'"></div>
              </div>
              <div class="col-6">
                <div class="sponsor-logo-box"><img src="/logo/indofood.png" alt="Indofood"
                    onerror="this.src='https://via.placeholder.com/100x40?text=Indofood'"></div>
              </div>
              <div class="col-6">
                <div class="sponsor-logo-box"><img src="/logo/gofood.png" alt="GoFood"
                    onerror="this.src='https://via.placeholder.com/100x40?text=GoFood'"></div>
              </div>
              <div class="col-6">
                <div class="sponsor-logo-box"><img src="/logo/tokped.png" alt="Tokopedia"
                    onerror="this.src='https://via.placeholder.com/100x40?text=Tokopedia'"></div>
              </div>
            </div>
          </div>
        </div>

        <div class="col-lg-2 col-md-4 col-sm-12 mt-4 mt-md-0">
          <h4>HELP CENTER</h4>
          <ul>
            <li><a href="/privacy">Privacy Policy</a></li>
          </ul>
        </div>

        <div class="col-lg-4 col-md-12 mt-4 mt-lg-0">
          <h4>CONTACT US</h4>
          <div class="contact-item">
            <img src="/icon/tlp.png" alt="phone" onerror="this.outerHTML='<span style=\'font-size:20px;\'>📞</span>'" />
            889070999
          </div>
          <div class="contact-item">
            <img src="/icon/wa.png" alt="whatsapp"
              onerror="this.outerHTML='<span style=\'font-size:20px;\'>📱</span>'" /> +62 887 1447 0009
          </div>
          <div class="contact-item">
            <img src="/icon/ig.png" alt="instagram"
              onerror="this.outerHTML='<span style=\'font-size:20px;\'>📸</span>'" /> @YumYum_Bakery
          </div>
          <div class="mt-pengaduan">
            <h4>LAYANAN PENGADUAN</h4>
            <div class="complaint-section">
              <p>PT Matahari Bulan Bintang Angkasa</p>
              <p>Email : marketing@yumyum.com</p>
              <p>0867 0000 1222 (WhatsApp)</p>
            </div>
          </div>
        </div>
      </div>

      <hr class="footer-divider" />
      <p class="footer-bottom">© 2024 YumYum Bakery. All rights reserved.</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      const API_BASE = 'http://localhost:3000/api';


      const HOME_MENU_TARGETS = [
        'Birthday cake',
        'Caramel Macchiato',
        'Macaron',
        'Strawberry Danish',
        'Cookies',
        'Strawberry milk'
      ].map(name => name.toLowerCase());

      function formatRupiah(num) {
        return 'Rp ' + Number(num).toLocaleString('id-ID');
      }

      function renderSkeletons() {
        const grid = document.getElementById('productsGrid');
        grid.innerHTML = Array(6).fill(`
      <div class="col-lg-4 col-md-6">
        <div class="skeleton-card">
          <div class="skeleton-img"></div>
          <div class="skeleton-text"></div>
          <div class="skeleton-text short"></div>
        </div>
      </div>
    `).join('');
      }

      async function fetchHomePageProducts() {
        renderSkeletons();
        try {
          const res = await fetch(`${API_BASE}/menu`);
          const json = await res.json();

          if (!json.success) throw new Error(json.message);


          const displayProducts = json.data.filter(p =>
            HOME_MENU_TARGETS.includes(p.name.toLowerCase())
          );

          renderProducts(displayProducts);
        } catch (err) {
          document.getElementById('productsGrid').innerHTML = `
        <div class="col-12 text-center py-5">
          <p>Gagal memuat produk. Pastikan server backend berjalan.</p>
        </div>`;
        }
      }

      function renderProducts(products) {
        const grid = document.getElementById('productsGrid');

        grid.innerHTML = products.map(p => `
      <div class="col-lg-4 col-md-6">
        <div class="product-card">
          <img src="${p.img_url || ''}" alt="${p.name}"
               onerror="this.src='https://images.unsplash.com/photo-1555507036-ab1f4038808a?w=400&h=400&fit=crop'" />
          <div class="product-card-info">
            <p class="sub-cat-label">${p.sub_category} · ${p.category}</p>
            <h3>${p.name}</h3>
            <p class="price">${formatRupiah(p.price)}</p>
            <a href="/menu/${p.id}" class="btn-add-card">+ Tambah ke Keranjang</a>
          </div>
        </div>
      </div>
    `).join('');


        document.getElementById('seeMoreWrap').style.display = 'block';
      }

      fetchHomePageProducts();

      async function addToCart(productId, event) {

        if (event) {
          event.preventDefault();
          event.stopPropagation();
        }

        try {
          const response = await fetch('http://localhost:3000/cart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ product_id: productId, quantity: 1 })
          });

          if (response.ok) {
            alert("Produk berhasil ditambahkan ke keranjang!");
          } else {
            alert("Gagal menambahkan produk ke keranjang.");
          }
        } catch (error) {
          console.error("Gagal memproses keranjang:", error);
        }
      }

      document.addEventListener('DOMContentLoaded', () => {
        const searchInput = document.getElementById('searchInput');
        if (searchInput) {

          searchInput.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
              e.preventDefault();
              const keyword = this.value.trim();
              if (keyword) {

                window.location.href = `/menu?search=${encodeURIComponent(keyword)}`;
              }
            }
          });
        }
      });

    </script>

</body>

</html>