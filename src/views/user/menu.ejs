        <li class="nav-item"><a class="nav-link" href="/">MENU</a></li>
        <li class="nav-item"><a class="nav-link" href="/store">STORE</a></li>
        <li class="nav-item"><a class="nav-link" href="about_us">ABOUT US</a></li>
        <li class="nav-item"><a class="nav-link" href="/history">HISTORY</a></li>
      </ul>
      <div class="d-flex align-items-center gap-3 mt-2 mt-lg-0">

    <a href="/cart" class="btn-cart-navbar">
        <span>CART</span>
        <img src="/icon/keranjang.png" alt="Cart">
    </a>

    <% if (typeof user !== "undefined" && user) { %>

        <a href="/logout" class="btn-login-navbar">
            LOGOUT
        </a>

    <% } else { %>

        <a href="/login" class="btn-login-navbar">
            LOGIN/SIGN UP
        </a>

    <% } %>

</div>
    </div>
  </div>
</nav>

<div class="page-header">
  <div class="breadcrumb-row"><a href="/">Home</a> <span>&gt;</span> <span class="current">Menu</span></div>
  <div class="page-title-wrap"><span class="page-title">BUAT MOMEN SPESIAL MU LEBIH MANIS</span></div>
</div>

<div class="category-overview-container">
  <div class="cat-column">
    <button class="cat-btn" onclick="scrollToSection('food')">FOOD</button>
    <div id="foodSubcatGrid" class="subcat-grid"></div>
  </div>
  <div class="cat-divider-wrap"><span class="cat-divider-text">Categories</span><div class="cat-divider-line"></div></div>
  <div class="cat-column">
    <button class="cat-btn" onclick="scrollToSection('drink')">DRINK</button>
    <div id="drinkSubcatGrid" class="subcat-grid"></div>
  </div>
</div>

<div class="menu-content" id="menuContent">
  <div id="menuSections"><div style="text-align:center; padding:60px 0; color:#999;">Memuat menu...</div></div>
</div>

<footer>
  <div class="row g-4 mb-4">
    <div class="col-lg-3 col-md-4 col-sm-6">
      <div class="d-flex flex-column align-items-start">
        <img src="/logo/logo_aja.png" alt="YumYum Bakery Logo" class="footer-logo-main"
             onerror="this.src='https://via.placeholder.com/200x100?text=YumYum+Logo'"/>
        <img src="/icon/icon halal.png" alt="Halal" class="footer-halal"
             onerror="this.src='https://via.placeholder.com/80?text=Halal'"/>
      </div>
    </div>

    <div class="col-lg-3 col-md-4 col-sm-6">
      <h4>YUMYUM BAKERY</h4>
      <ul>
        <li><a href="about_us">About Us</a></li>
        <li><a href="commentForm">Contact</a></li>
      </ul>
      <div class="mt-sponsor">
        <h4>SPONSOR</h4>
        <div class="row g-2">
          <div class="col-6"><div class="sponsor-logo-box"><img src="/logo/anchor.png" alt="Anchor" onerror="this.src='https://via.placeholder.com/100x40?text=Anchor'"></div></div>
          <div class="col-6"><div class="sponsor-logo-box"><img src="/logo/indofood.png" alt="Indofood" onerror="this.src='https://via.placeholder.com/100x40?text=Indofood'"></div></div>
          <div class="col-6"><div class="sponsor-logo-box"><img src="/logo/gofood.png" alt="GoFood" onerror="this.src='https://via.placeholder.com/100x40?text=GoFood'"></div></div>
          <div class="col-6"><div class="sponsor-logo-box"><img src="/logo/tokped.png" alt="Tokopedia" onerror="this.src='https://via.placeholder.com/100x40?text=Tokopedia'"></div></div>
        </div>
      </div>
    </div>

    <div class="col-lg-2 col-md-4 col-sm-12 mt-4 mt-md-0">
      <h4>HELP CENTER</h4>
      <ul>
        <li><a href="privacy">Privacy Policy</a></li>
      </ul>
    </div>

    <div class="col-lg-4 col-md-12 mt-4 mt-lg-0">
      <h4>CONTACT US</h4>
      <div class="contact-item">
        <img src="/icon/tlp.png" alt="phone" onerror="this.outerHTML='<span style=\'font-size:20px;\'>📞</span>'" /> 889070999
      </div>
      <div class="contact-item">
        <img src="/icon/wa.png" alt="whatsapp" onerror="this.outerHTML='<span style=\'font-size:20px;\'>📱</span>'" /> +62 887 1447 0009
      </div>
      <div class="contact-item">
        <img src="/icon/ig.png" alt="instagram" onerror="this.outerHTML='<span style=\'font-size:20px;\'>📸</span>'" /> @YumYum_Bakery
      </div>
      <div class="mt-pengaduan">
        <h4>LAYANAN PENGADUAN</h4>
        <div class="complaint-section">
          <p>PT Matahari Bulan Bintang Angkasa</p>
          <p>Email : marketing@yumyum.com</p>
          <p>0867 0000 1222 (WhatsApp)</p>
        </div>
      </div>
    </div>
  </div>

  <hr class="footer-divider"/>
  <p class="footer-bottom">© 2024 YumYum Bakery. All rights reserved.</p>
</footer>

<script>
  const API_BASE = '';
  const displayNames = {
    'Roti & Pastry': 'PASTRY', 'Cake & Dessert': 'CAKE',
    'Cookies & Snack': 'COOKIES', 'Savory': 'SAVORY',
    'Coffee': 'COFFEE', 'Non-Coffee': 'NON-COFFEE'
  };

  function formatRupiah(num) { return 'Rp.' + Number(num).toLocaleString('id-ID'); }
  function slugify(str) { return str.toLowerCase().replace(/[^a-z0-9]/g, '-'); }

  function scrollToSection(type) {
    const target = document.getElementById('section-' + type) || document.getElementById('anchor-' + type);
    if (target) window.scrollTo({top: target.getBoundingClientRect().top + window.scrollY - 100, behavior: 'smooth'});
  }

  async function fetchMenuData() {
    try {
      const fetchUrl = `${API_BASE}/api/menu`;
      const res = await fetch(fetchUrl);
      const json = await res.json();
      
      if (json.success) {
        buildCategoryOverview(json.data);
        buildMenuSections(json.data);
      }
    } catch (err) { 
      console.error("Gagal load data", err); 
      document.getElementById('menuSections').innerHTML = `<div style="text-align:center; padding:60px 0; color:#999;">Gagal mengambil data dari server.</div>`;
    }
  }

  function buildCategoryOverview(products) {
    const foodSubcats = {};
    const drinkItems = { 'Coffee': [], 'Non-Coffee': [] };

    products.forEach(p => {
      if (p.category === 'Makanan') {
        if (!foodSubcats[p.sub_category]) foodSubcats[p.sub_category] = p.img_url;
      } else if (p.category === 'Minuman') {
        if (drinkItems[p.sub_category] && drinkItems[p.sub_category].length < 2) {
          drinkItems[p.sub_category].push(p.img_url);
        }
      }
    });

    document.getElementById('foodSubcatGrid').innerHTML = Object.entries(foodSubcats).map(([name, img]) => `
      <div class="subcat-card" onclick="scrollToSection('${slugify(name)}')">
        <img src="${img}" alt="${name}" />
        <div class="subcat-card-label">${displayNames[name] || name}</div>
      </div>`).join('');

    let drinkHtml = '';
    Object.entries(drinkItems).forEach(([name, images]) => {
      images.forEach(img => {
        drinkHtml += `
          <div class="subcat-card" onclick="scrollToSection('${slugify(name)}')">
            <img src="${img}" alt="${name}" />
            <div class="subcat-card-label">${displayNames[name] || name}</div>
          </div>`;
      });
    });
    document.getElementById('drinkSubcatGrid').innerHTML = drinkHtml;
  }

  function buildMenuSections(products) {
    const grouped = {};
    products.forEach(p => {
      if (!grouped[p.sub_category]) grouped[p.sub_category] = [];
      grouped[p.sub_category].push(p);
    });

    const orderedKeys = Object.keys(displayNames).filter(k => grouped[k]);
    const foodKeys = ['Roti & Pastry', 'Cake & Dessert', 'Cookies & Snack', 'Savory'];
    const firstFood = orderedKeys.find(k => foodKeys.includes(k));
    const firstDrink = orderedKeys.find(k => !foodKeys.includes(k));

    let html = '';
    orderedKeys.forEach((subcat, idx) => {
      if (idx > 0) html += `<div class="section-divider-line"></div>`;
      html += `
        <div class="product-section section-anchor" id="section-${slugify(subcat)}">
          ${subcat === firstFood ? '<span id="anchor-food"></span>' : ''}
          ${subcat === firstDrink ? '<span id="anchor-drink"></span>' : ''}
          <div class="section-title-wrap"><div class="section-title-line"></div><span class="section-title-text">${displayNames[subcat]}</span><div class="section-title-line"></div></div>
          <div class="product-row">
            ${grouped[subcat].map(p => `
              <div class="menu-card">
                <div class="menu-card-img-wrap"><img src="${p.img_url || ''}" alt="${p.name}" /><a href="/menu/${p.id}" class="btn-add-overlay">Add To Cart</a></div>
                <div class="menu-card-name">${p.name}</div>
                <div class="menu-card-price">${formatRupiah(p.price)}</div>
              </div>`).join('')}
          </div>
        </div>`;
    });
    document.getElementById('menuSections').innerHTML = html;
  }

  fetchMenuData();

  async function addToCart(productId, event) {
    if (event) {
      event.preventDefault();
      event.stopPropagation();
    }

    try {
      const response = await fetch('http://localhost:3000/cart', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ product_id: productId, quantity: 1 })
      });
      
      if (response.ok) {
        alert("Produk berhasil ditambahkan ke keranjang!");
      } else {
        alert("Gagal menambahkan produk ke keranjang.");
      }
    } catch (error) {
      console.error("Gagal memproses keranjang:", error);
    }
  }

</script>
</body>
</html>