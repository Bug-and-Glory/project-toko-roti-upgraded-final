<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Order Detail — YumYum Bakery</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@400;600;700&display=swap"
    rel="stylesheet" />
  <style>
    :root {
      --navbar-bg: #4E2609;
      --footer-bg: #4E2609;
      --cart-btn: #754C27;
      --cream: #f5f0e8;
      --brown-dark: #3b1f0e;
      --brown-mid: #5c2d0e;
      --brown-light: #8b4513;
      --gold-light: #e8b84b;
      --text-dark: #2b1a0a;
      --text-gray: #666;
    }

    body {
      font-family: 'Poppins', sans-serif;
      background: var(--cream);
    }

    .navbar {
      background: var(--navbar-bg) !important;
      padding: 10px 48px;
      box-shadow: 0 3px 16px rgba(0, 0, 0, 0.3);
    }

    .nav-logo-img {
      height: 50px;
      width: auto;
      object-fit: contain;
    }

    .nav-logo-fallback {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .nav-logo-fallback .logo-box {
      width: 48px;
      height: 48px;
      background: var(--cart-btn);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .nav-logo-fallback .brand-name {
      font-family: 'Playfair Display', serif;
      font-weight: 700;
    }

    .nav-logo-fallback .brand-sub {
      letter-spacing: 2px;
      text-transform: uppercase;
      font-size: 11px;
    }

    .navbar-nav .nav-link {
      font-family: 'Poppins', sans-serif;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #fff;
    }

    .navbar-nav .nav-link:hover {
      color: var(--gold-light) !important;
    }

    .btn-cart {
      background: var(--cart-btn);
      color: #fff;
      border: none;
      padding: 10px 22px;
      border-radius: 8px;
      font-family: 'Marmelad', sans-serif;
      font-size: 15px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 8px;
      box-shadow: 0 4px 18px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.18);
      transition: background 0.2s, transform 0.15s;
    }

    .btn-cart:hover {
      background: #8a5c30;
      transform: translateY(-1px);
    }

    .btn-cart img {
      width: 20px;
      height: 20px;
      filter: brightness(0) invert(1);
    }

    .cart-badge {
      position: absolute;
      top: -8px;
      right: -8px;
      background: #e74c3c;
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      display: none;
    }

    .search-wrapper {
      position: relative;
      display: flex;
      align-items: center;
    }

    #searchInput {
      width: 0;
      opacity: 0;
      padding: 0;
      border: none;
      outline: none;
      background: rgba(255, 255, 255, 0.15);
      color: #fff;
      font-family: 'Poppins', sans-serif;
      font-size: 13px;
      border-radius: 8px;
      transition: width 0.35s ease, opacity 0.35s ease, padding 0.35s ease;
    }

    #searchInput::placeholder {
      color: rgba(255, 255, 255, 0.6);
    }

    #searchInput.open {
      width: 200px;
      opacity: 1;
      padding: 8px 14px;
      margin-right: 8px;
    }

    .btn-search {
      background: rgba(255, 255, 255, 0.42);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255, 255, 255, 0.35);
      width: 44px;
      height: 44px;
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 14px rgba(0, 0, 0, 0.25);
      transition: background 0.2s;
    }

    .btn-search:hover {
      background: rgba(255, 255, 255, 0.6);
    }

    .btn-search img {
      width: 20px;
      height: 20px;
    }

    .order-container {
      max-width: 1000px;
      margin: 60px auto;
      background: #fff;
      border-radius: 20px;
      padding: 40px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    }

    .product-img {
      width: 100%;
      border-radius: 16px;
      aspect-ratio: 1/1;
      object-fit: cover;
    }

    .qty-box {
      display: flex;
      align-items: center;
      border: 1px solid #ddd;
      border-radius: 25px;
      padding: 5px 15px;
      width: fit-content;
    }

    .qty-btn {
      background: none;
      border: none;
      font-size: 20px;
      cursor: pointer;
      padding: 0 10px;
    }

    .btn-save {
      background: var(--brown-dark);
      color: #fff;
      border-radius: 25px;
      padding: 10px 30px;
      border: none;
    }

    footer {
      background: var(--footer-bg);
      color: rgba(255, 255, 255, 0.9);
      padding: 60px 48px 30px;
      font-family: 'Poppins', sans-serif;
    }

    .footer-logo-main {
      width: 100%;
      max-width: 220px;
      border: 1.5px solid #dcb786;
      padding: 8px;
      margin-bottom: 30px;
      object-fit: contain;
    }

    .footer-halal {
      width: 85px;
      height: 85px;
      object-fit: contain;
    }

    footer h4 {
      font-family: 'Poppins', sans-serif;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #fff;
      margin-bottom: 14px;
    }

    footer ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    footer ul li {
      margin-bottom: 8px;
    }

    footer ul li a {
      text-decoration: none;
      color: rgba(255, 255, 255, 0.7);
      font-size: 13px;
      transition: color 0.2s;
    }

    footer ul li a:hover {
      color: var(--gold-light);
    }

    .contact-item {
      display: flex;
      align-items: center;
      gap: 10px;
      color: rgba(255, 255, 255, 0.8);
      font-size: 13px;
      margin-bottom: 10px;
    }

    .contact-item img {
      width: 20px;
      height: 20px;
      object-fit: contain;
      filter: brightness(0) invert(1);
      opacity: 0.85;
    }

    .mt-sponsor {
      margin-top: 32px;
    }

    .sponsor-logo-box {
      background: #fff;
      border-radius: 8px;
      padding: 8px 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      height: 40px;
      overflow: hidden;
    }

    .sponsor-logo-box img {
      max-width: 100%;
      max-height: 20px;
      object-fit: contain;
    }

    .mt-pengaduan {
      margin-top: 32px;
    }

    .complaint-section p {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.7);
      line-height: 1.8;
      margin-bottom: 0;
    }

    .footer-divider {
      border: none;
      border-top: 1px solid rgba(255, 255, 255, 0.15);
      margin: 40px 0 16px;
    }

    .footer-bottom {
      text-align: center;
      font-size: 12px;
      color: rgba(255, 255, 255, 0.4);
    }

    @media (max-width: 992px) {
      .navbar {
        padding: 10px 20px;
      }

      .hero-wrapper {
        padding: 30px 20px 60px;
      }

      .hero-slide {
        aspect-ratio: 16 / 7;
      }

      .products-grid-section,
      .category-tabs {
        padding: 16px 20px;
      }

      .reviews-section {
        padding: 40px 20px 60px;
      }

      footer {
        padding: 40px 20px 20px;
      }
    }
  </style>
</head>

<body>

  <nav class="navbar navbar-expand-lg sticky-top">
    <div class="container-fluid px-0">
      <a class="navbar-brand ms-0" href="/">
        <img src="/assets/logo/logo_nama.png" alt="YumYum Bakery" class="nav-logo-img"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
        <div class="nav-logo-fallback" style="display:none;">
          <div class="logo-box">
            <svg viewBox="0 0 48 48" fill="none" width="32" height="32">
              <ellipse cx="24" cy="28" rx="16" ry="10" fill="#c9922a" />
              <ellipse cx="24" cy="26" rx="14" ry="8" fill="#e8b84b" />
              <path d="M16 18 Q24 10 32 18" stroke="#c9922a" stroke-width="2.5" fill="none" stroke-linecap="round" />
              <text x="15" y="33" font-size="9" font-weight="bold" fill="#3b1f0e" font-family="serif">YB</text>
            </svg>
          </div>
          <div>
            <span class="brand-name" style="color:#fff">YumYum</span>
            <span class="brand-sub d-block" style="color:rgba(255,255,255,0.7)">Bakery</span>
          </div>
        </div>
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarMain">
        <ul class="navbar-nav mx-auto">
          <li class="nav-item"><a class="nav-link" href="/menu">MENU</a></li>
          <li class="nav-item"><a class="nav-link" href="/store">STORE</a></li>
          <li class="nav-item"><a class="nav-link" href="/about_us">ABOUT US</a></li>
          <li class="nav-item"><a class="nav-link" href="/history">HISTORY</a></li>
        </ul>
        <div class="d-flex align-items-center gap-3 mt-2 mt-lg-0">
          <a href="/cart" class="btn-cart">
            <img src="/assets/icon/keranjang.png" alt="Cart"> CART
            <span class="cart-badge" id="cartBadge">0</span>
          </a>
        </div>
      </div>
    </div>
  </nav>

  <div class="container order-container">
    <div id="loader" class="text-center py-5">
      <div class="spinner-border"></div>
    </div>

    <div id="content" class="row align-items-center d-none">
      <div class="col-md-5">
        <img id="p-img" src="" class="product-img" alt="Product">
      </div>
      <div class="col-md-7 ps-md-5">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/menu">Menu</a></li>
            <li class="breadcrumb-item active" id="p-cat">Category</li>
          </ol>
        </nav>
        <h1 id="p-name" class="fw-bold" style="font-family: 'Playfair Display';">Nama Menu</h1>
        <p id="p-desc" class="text-muted">Deskripsi produk...</p>
        <h3 id="p-price" class="fw-bold text-brown mb-4">Rp 0</h3>

        <div class="d-flex align-items-center gap-3 mb-4">
          <div class="qty-box">
            <button class="qty-btn" onclick="updateQty(-1)">-</button>
            <span id="qty-val" class="mx-3 fw-bold">1</span>
            <button class="qty-btn" onclick="updateQty(1)">+</button>
          </div>
        </div>

        <div class="d-flex gap-2">
          <button class="btn-save" onclick="saveToCart()">Simpan ke Keranjang</button>
        </div>
      </div>
    </div>
  </div>

  <div class="modal fade" id="receiptModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content p-4">
        <div class="text-center">
          <h4 class="fw-bold">YumYum Bakery</h4>
          <p class="text-muted small">Struk Pembelian Terkonfirmasi</p>
          <hr style="border-top: 2px dashed #bbb;">
        </div>
        <div class="d-flex justify-content-between"><span id="r-item">Item x1</span><span id="r-price">Rp 0</span></div>
        <div class="d-flex justify-content-between fw-bold mt-3"><span>TOTAL</span><span id="r-total">Rp 0</span></div>
        <button class="btn btn-dark w-100 mt-4 rounded-pill" onclick="location.href='/'">Kembali ke Beranda</button>
      </div>
    </div>
  </div>

  <footer>
  <div class="row g-4 mb-4">
    <div class="col-lg-3 col-md-4 col-sm-6">
      <div class="d-flex flex-column align-items-start">
        <img src="/assets/logo/logo_aja.png" alt="YumYum Bakery Logo" class="footer-logo-main"
             onerror="this.src='https://via.placeholder.com/200x100?text=YumYum+Logo'"/>
        <img src="/assets/icon/icon halal.png" alt="Halal" class="footer-halal"
             onerror="this.src='https://via.placeholder.com/80?text=Halal'"/>
      </div>
    </div>

    <div class="col-lg-3 col-md-4 col-sm-6">
      <h4>YUMYUM BAKERY</h4>
      <ul>
        <li><a href="/about_us">About Us</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <div class="mt-sponsor">
        <h4>SPONSOR</h4>
        <div class="row g-2">
          <div class="col-6"><div class="sponsor-logo-box"><img src="/assets/logo/anchor.png" alt="Anchor" onerror="this.src='https://via.placeholder.com/100x40?text=Anchor'"></div></div>
          <div class="col-6"><div class="sponsor-logo-box"><img src="/assets/logo/indofood.png" alt="Indofood" onerror="this.src='https://via.placeholder.com/100x40?text=Indofood'"></div></div>
          <div class="col-6"><div class="sponsor-logo-box"><img src="/assets/logo/gofood.png" alt="GoFood" onerror="this.src='https://via.placeholder.com/100x40?text=GoFood'"></div></div>
          <div class="col-6"><div class="sponsor-logo-box"><img src="/assets/logo/tokped.png" alt="Tokopedia" onerror="this.src='https://via.placeholder.com/100x40?text=Tokopedia'"></div></div>
        </div>
      </div>
    </div>

    <div class="col-lg-2 col-md-4 col-sm-12 mt-4 mt-md-0">
      <h4>HELP CENTER</h4>
      <ul>
        <li><a href="/privacy">Privacy Policy</a></li>
      </ul>
    </div>

    <div class="col-lg-4 col-md-12 mt-4 mt-lg-0">
      <h4>CONTACT US</h4>
      <div class="contact-item">
        <img src="/assets/icon/tlp.png" alt="phone" onerror="this.outerHTML='<span style=\'font-size:20px;\'>📞</span>'" /> 889070999
      </div>
      <div class="contact-item">
        <img src="assets/icon/wa.png" alt="whatsapp" onerror="this.outerHTML='<span style=\'font-size:20px;\'>📱</span>'" /> +62 887 1447 0009
      </div>
      <div class="contact-item">
        <img src="/assets/icon/ig.png" alt="instagram" onerror="this.outerHTML='<span style=\'font-size:20px;\'>📸</span>'" /> @YumYum_Bakery
      </div>
      <div class="mt-pengaduan">
        <h4>LAYANAN PENGADUAN</h4>
        <div class="complaint-section">
          <p>PT Matahari Bulan Bintang Angkasa</p>
          <p>Email : marketing@yumyum.com</p>
          <p>0867 0000 1222 (WhatsApp)</p>
        </div>
      </div>
    </div>
  </div>

  <hr class="footer-divider"/>
  <p class="footer-bottom">© 2024 YumYum Bakery. All rights reserved.</p>

</footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const API_BASE = '';
    const pathParts = window.location.pathname.split("/");
    const productId = pathParts[pathParts.length - 1];
    let product = null;
    let qty = 1;

    async function loadDetail() {
      try {
        const res = await fetch(`${API_BASE}/api/menu/${productId}`);
        const json = await res.json();
        if (json.success) {
          product = json.data;
          document.getElementById('p-img').src = product.img_url;
          document.getElementById('p-name').textContent = product.name;
          document.getElementById('p-cat').textContent = product.sub_category;
          document.getElementById('p-desc').textContent = product.description || "Freshly baked everyday.";
          document.getElementById('p-price').textContent = `Rp ${Number(product.price).toLocaleString('id-ID')}`;
          document.getElementById('loader').classList.add('d-none');
          document.getElementById('content').classList.remove('d-none');
        }
      } catch (e) { alert("Produk gagal dimuat."); }
    }

    function updateQty(val) {
      qty = Math.max(1, qty + val);
      document.getElementById('qty-val').textContent = qty;
    }

    function saveToCart() {
      let cart = JSON.parse(localStorage.getItem('yumyum_cart')) || [];

      // Cek apakah produk yang sama sudah ada di keranjang
      const existingItemIndex = cart.findIndex(item => item.product_id === product.id);

      if (existingItemIndex > -1) {
        cart[existingItemIndex].quantity += qty;
      } else {
        cart.push({
          product_id: product.id,
          name: product.name,
          price: product.price,
          img_url: product.img_url,
          quantity: qty
        });
      }

      localStorage.setItem('yumyum_cart', JSON.stringify(cart));

      alert("Berhasil disimpan ke keranjang!");

      window.location.href = '/menu';
    }


    if (productId) loadDetail();

    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('searchInput');
      if (searchInput) {
        searchInput.addEventListener('keypress', function (e) {
          if (e.key === 'Enter') {
            e.preventDefault();
            const keyword = this.value.trim();
            if (keyword) {
              window.location.href = `/menu?search=${encodeURIComponent(keyword)}`;
            }
          }
        });
      }
    });
  </script>
</body>

</html>