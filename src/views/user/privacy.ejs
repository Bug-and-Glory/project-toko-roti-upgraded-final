<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
      searchInput.addEventListener('keypress', function (e) {
        if (e.key === 'Enter') {
          e.preventDefault();
          const keyword = this.value.trim();
          if (keyword) window.location.href = `/menu?search=${encodeURIComponent(keyword)}`;
        }
      });
    }

    const cookieBanner = document.getElementById('cookieBanner');
    const btnAcceptCookies = document.getElementById('btnAcceptCookies');

    if (!localStorage.getItem('cookieConsentAccepted')) {
      cookieBanner.style.display = 'flex';
    }

    btnAcceptCookies.addEventListener('click', async () => {
      cookieBanner.style.display = 'none';
      localStorage.setItem('cookieConsentAccepted', 'true');

      try {
        const response = await fetch('/api/cookies/consent', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ 
            consent: true, 
            timestamp: new Date().toISOString() 
          })
        });

        if (!response.ok) {
          console.warn("Persetujuan cookie gagal disimpan ke server, namun sudah tersimpan di browser (lokal).");
        }
      } catch (error) {
        console.error("Gagal terhubung ke API:", error);
      }
    });
  });
</script>

