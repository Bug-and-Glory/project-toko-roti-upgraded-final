<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Privacy Policy - YumYum Bakery</title>

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>

  <style>
    :root {
      --navbar-bg:   #4E2609;
      --footer-bg:   #4E2609;
      --cart-btn:    #754C27;
      --cream:       #f5f0e8;
      --brown-dark:  #3b1f0e;
      --brown-mid:   #5c2d0e;
      --brown-light: #8b4513;
      --gold:        #c9922a;
      --gold-light:  #e8b84b;
      --white:       #fff;
      --text-dark:   #2b1a0a;
      --text-gray:   #666;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Poppins', sans-serif; background: var(--cream); color: var(--text-dark); }

    .navbar { background: var(--navbar-bg) !important; padding: 10px 48px; box-shadow: 0 3px 16px rgba(0,0,0,0.3); }
    .nav-logo-img { height: 50px; width: auto; object-fit: contain; }
    .nav-logo-fallback { display: flex; align-items: center; gap: 10px; }
    .nav-logo-fallback .logo-box { width: 48px; height: 48px; background: var(--cart-btn); border-radius: 8px; display: flex; align-items: center; justify-content: center; }
    .nav-logo-fallback .brand-name { font-family: 'Playfair Display', serif; font-weight: 700; }
    .nav-logo-fallback .brand-sub { letter-spacing: 2px; text-transform: uppercase; font-size: 11px; }
    .navbar-nav .nav-link { font-family: 'Poppins', sans-serif; font-size: 13px; font-weight: 500; letter-spacing: 1px; text-transform: uppercase; color: #fff; }
    .navbar-nav .nav-link:hover { color: var(--gold-light) !important; }
    
    .btn-cart { background: var(--cart-btn); color: #fff; border: none; padding: 10px 22px; border-radius: 8px; font-size: 15px; cursor: pointer; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 18px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.18); transition: background 0.2s, transform 0.15s; text-decoration: none; }
    .btn-cart:hover { background: #8a5c30; transform: translateY(-1px); color: #fff; }
    .btn-cart img { width: 20px; height: 20px; filter: brightness(0) invert(1); }
    .cart-badge { position: absolute; top: -8px; right: -8px; background: #e74c3c; color: #fff; font-size: 11px; font-weight: 700; width: 20px; height: 20px; border-radius: 50%; display: none; align-items: center; justify-content: center; }
    
    .search-wrapper { position: relative; display: flex; align-items: center; }
    #searchInput { width: 0; opacity: 0; padding: 0; border: none; outline: none; background: rgba(255,255,255,0.15); color: #fff; font-family: 'Poppins', sans-serif; font-size: 13px; border-radius: 8px; transition: width 0.35s ease, opacity 0.35s ease, padding 0.35s ease; }
    #searchInput::placeholder { color: rgba(255,255,255,0.6); }
    #searchInput.open { width: 200px; opacity: 1; padding: 8px 14px; margin-right: 8px; }
    .btn-search { background: rgba(255,255,255,0.42); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.35); width: 44px; height: 44px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 14px rgba(0,0,0,0.25); transition: background 0.2s; }
    .btn-search:hover { background: rgba(255,255,255,0.6); }
    .btn-search img { width: 20px; height: 20px; }

    .privacy-header { text-align: center; padding: 60px 20px 30px; }
    .privacy-header h1 { font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 700; color: var(--text-dark); text-transform: uppercase; letter-spacing: 1px; margin: 0; }
    
    .privacy-content { max-width: 800px; margin: 0 auto; padding: 0 30px 80px; font-family: 'Poppins', sans-serif; }
    .privacy-content p { font-size: 14px; color: var(--text-dark); line-height: 1.6; margin-bottom: 20px; text-align: justify; }
    .privacy-content strong { font-weight: 700; color: var(--text-dark); }
    .privacy-content a { color: var(--brown-light); text-decoration: none; }
    .privacy-content a:hover { text-decoration: underline; }

    .cookie-banner { position: fixed; bottom: 0; left: 0; right: 0; background: var(--brown-dark); color: #fff; padding: 15px 30px; display: none; align-items: center; justify-content: space-between; z-index: 1050; box-shadow: 0 -4px 15px rgba(0,0,0,0.2); }
    .cookie-banner p { margin: 0; font-size: 13px; font-family: 'Poppins', sans-serif; line-height: 1.5; }
    .btn-cookie { background: var(--gold-light); border: none; color: var(--brown-dark); font-weight: 600; padding: 8px 24px; border-radius: 6px; cursor: pointer; font-size: 13px; transition: background 0.2s; white-space: nowrap; }
    .btn-cookie:hover { background: var(--gold); color: #fff; }

    footer { background: var(--footer-bg); color: rgba(255,255,255,0.9); padding: 60px 48px 30px; font-family: 'Poppins', sans-serif; }
    .footer-logo-main { width: 100%; max-width: 220px; border: 1.5px solid #dcb786; padding: 8px; margin-bottom: 30px; object-fit: contain; }
    .footer-halal { width: 85px; height: 85px; object-fit: contain; }
    footer h4 { font-family: 'Poppins', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: #fff; margin-bottom: 14px; }
    footer ul { list-style: none; padding: 0; margin: 0; }
    footer ul li { margin-bottom: 8px; }
    footer ul li a { text-decoration: none; color: rgba(255,255,255,0.7); font-size: 13px; transition: color 0.2s; }
    footer ul li a:hover { color: var(--gold-light); }
    .contact-item { display: flex; align-items: center; gap: 10px; color: rgba(255,255,255,0.8); font-size: 13px; margin-bottom: 10px; }
    .contact-item img { width: 20px; height: 20px; object-fit: contain; filter: brightness(0) invert(1); opacity: 0.85; }
    .mt-sponsor { margin-top: 32px; }
    .sponsor-logo-box { background: #fff; border-radius: 8px; padding: 8px 10px; display: flex; align-items: center; justify-content: center; height: 40px; overflow: hidden; }
    .sponsor-logo-box img { max-width: 100%; max-height: 20px; object-fit: contain; }
    .mt-pengaduan { margin-top: 32px; }
    .complaint-section p { font-size: 12px; color: rgba(255,255,255,0.7); line-height: 1.8; margin-bottom: 0; }
    .footer-divider { border: none; border-top: 1px solid rgba(255,255,255,0.15); margin: 40px 0 16px; }
    .footer-bottom { text-align: center; font-size: 12px; color: rgba(255,255,255,0.4); }

    @media (max-width: 992px) {
      .navbar { padding: 10px 20px; }
      .privacy-content { padding: 0 20px 50px; }
      .cookie-banner { flex-direction: column; text-align: center; gap: 15px; }
      footer { padding: 40px 20px 20px; }
    }
  </style>
</head>
