<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Our Store — YumYum Bakery</title>

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/store.css">
  <link rel="stylesheet" href="/css/index.css">
</head>
<body>

<%- include('navbar') %>

<div class="container store-container">
  <div class="store-header">
    <h1>Our Store</h1>
    <p>We strive to make your life much easier. Our ever-expanding stores are located all over Indonesia, where you can pamper yourself or spend quality time with loved ones in a luxurious environment with a pleasant ambiance.</p>
  </div>

  <div id="loader" class="text-center py-5">
    <div class="spinner-border text-secondary" role="status"></div>
    <p class="mt-3 text-muted">Memuat lokasi toko...</p>
  </div>

  <div id="store-grid" style="display: none;">
    </div>
</div>

<%- include('footer') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const API_BASE = 'http://localhost:3000';

  const fallbackStores = [
    {
      id: 1,
      name: "YUMYUM BAKERY CABANG MEDAN",
      address: "Jl. Angkasa Bintang Dilangit No.53. Talang angin, kec. Bintang Kecil, Kota Medan, Sumatera Utara 20756",
      phone: "1500891",
      hours: "08:00 - 22:00",
      image_url: "/gambar/store 1.png"
    },
    {
      id: 2,
      name: "YUMYUM BAKERY CABANG BANDUNG",
      address: "Jl. Dilan No.53. Bukit Indah, kec. Hitam Putih, Kota Bandung, Jawa Barat 70981",
      phone: "1500891",
      hours: "08:00 - 22:00",
      image_url: "/gambar/store 2.png"
    },
    {
      id: 3,
      name: "YUMYUM BAKERY CABANG BATAM",
      address: "Jl. Golden No.53, Bukit Indah, kec. Sungai Panas, Kota Batam, Kepulauan Riau 45708",
      phone: "1500891",
      hours: "08:00 - 22:00",
      image_url: "/gambar/store 3.png"
    }
  ];

  async function fetchStores() {
    try {
      const response = await fetch(`${API_BASE}/stores`);
      const json = await response.json();
      
      if (json.success && json.data) {
        renderStores(json.data); 
      } else {
        throw new Error("Gagal mengambil data dari endpoint");
      }
    } catch (error) {
      console.warn("Endpoint /stores belum tersedia. Menggunakan data fallback UI...", error);
      renderStores(fallbackStores); 
    }
  }

  function renderStores(stores) {
    document.getElementById('loader').style.display = 'none';
    const grid = document.getElementById('store-grid');
    grid.style.display = 'grid';

    const phoneIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>`;
    const clockIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512"><path d="M256 0a256 256 0 1 1 0 512A256 256 0 1 1 256 0zM232 120V256c0 8 4 15.5 10.7 20l96 64c11 7.4 25.9 4.4 33.3-6.7s4.4-25.9-6.7-33.3L280 243.2V120c0-13.3-10.7-24-24-24s-24 10.7-24 24z"/></svg>`;

    grid.innerHTML = stores.map(store => `
      <div class="store-card">
        <img src="${store.image_url}" alt="${store.name}" class="store-card-img" onerror="this.src='https://images.unsplash.com/photo-1555507036-ab1f4038808a?w=800&h=400&fit=crop'" />
        <div class="store-card-body">
          <h3 class="store-title">${store.name}</h3>
          <p class="store-address">${store.address}</p>
          
          <div class="store-info-row">
            <span class="store-info-icon">${phoneIcon}</span>
            <span>${store.phone}</span>
          </div>
          <div class="store-info-row">
            <span class="store-info-icon">${clockIcon}</span>
            <span>OPEN ${store.hours}</span>
          </div>
        </div>
      </div>
    `).join('');
  }

  document.addEventListener('DOMContentLoaded', () => {
    fetchStores(); 

    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
      searchInput.addEventListener('keypress', function (e) {
        if (e.key === 'Enter') {
          e.preventDefault();
          const keyword = this.value.trim();
          if (keyword) window.location.href = `menu.html?search=${encodeURIComponent(keyword)}`;
        }
      });
    }
  });
</script>
</body>
</html>